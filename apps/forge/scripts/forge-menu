#!/bin/sh

print_usage() {
  cat <<'USAGE'
Usage: forge-menu [--root ROOT_DIR]

Displays an interactive App Forge command console.
USAGE
}

case "${1-}" in
--help|--usage|-h)
  print_usage
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

if ! require menu "App Forge menu requires the 'menu' command."; then
  exit 1
fi

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/../../.." && pwd)

root_hint=''
while [ "$#" -gt 0 ]; do
  case "$1" in
    --root)
      root_hint=${2-}
      if [ -z "$root_hint" ]; then
        printf '%s\n' "forge-menu: --root requires ROOT_DIR" >&2
        exit 2
      fi
      shift 2
      ;;
    --help|--usage|-h)
      print_usage
      exit 0
      ;;
    *)
      printf '%s\n' "forge-menu: unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

root=${root_hint:-${WIZARDRY_APPS_ROOT:-$repo_root}}
PATH="$root/apps/forge/scripts:$root/tools/forge:$PATH"

if [ ! -x "$root/apps/forge/scripts/forge-backend" ]; then
  printf '%s\n' "forge-menu: invalid wizardry-apps root: $root" >&2
  exit 1
fi

trap 'exit 130' INT
trap 'exit 0' TERM

while :; do
  exit_label=$(exit-label)
  menu_title="App Forge console (root: $root)"

  menu "$menu_title" \
    "Quick cycle (run live host)%forge-backend run-desktop \"$root\" forge host" \
    "Run App Forge (desktop)%forge-backend run-desktop \"$root\" forge" \
    "Doctor workspace%forge-backend doctor \"$root\"" \
    "List builtin apps%forge-backend list-apps \"$root\"" \
    "List workspaces%forge-backend list-workspaces \"$root\"" \
    "List templates%forge-backend list-templates \"$root\"" \
    "List themes%forge-backend list-themes \"$root\"" \
    "List Godot tools%forge-backend list-godot-tools \"$root\"" \
    "---" \
    "Build App Forge (desktop)%forge-backend build-desktop \"$root\" forge" \
    "Stage mobile assets%forge-backend stage-mobile \"$root\" forge" \
    "Build Android debug%forge-backend build-android-debug \"$root\" forge" \
    "Build iOS smoke%forge-backend build-ios-smoke \"$root\" forge" \
    "---" \
    "Install App Forge launcher%install-forge --root \"$root\"" \
    "Uninstall App Forge launcher%uninstall-forge" \
    "Launch App Forge GUI%launch-forge --root \"$root\"" \
    "${exit_label}%kill -TERM \$PPID" || menu_status=$?

  menu_status=${menu_status:-0}
  [ "$menu_status" -eq 130 ] && exit 0
done
