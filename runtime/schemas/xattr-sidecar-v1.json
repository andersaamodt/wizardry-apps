{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardry.example/schemas/xattr-sidecar-v1.json",
  "title": "xattr sidecar metadata",
  "type": "object",
  "required": ["version", "docPath", "xattrs"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "docPath": {
      "type": "string",
      "minLength": 1
    },
    "xattrs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
