{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardry.app/schemas/native-desktop-ir-v1.json",
  "title": "Wizardry Native Desktop IR v1",
  "type": "object",
  "required": ["version", "format", "app", "extensions"],
  "properties": {
    "version": {
      "const": "native-desktop-ir/v1"
    },
    "format": {
      "const": "yaml-1.2-json-compatible"
    },
    "app": {
      "type": "object",
      "required": ["id", "name", "targets", "window"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "targets": {
          "type": "array",
          "items": {
            "enum": ["macos", "linux"]
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "window": {
          "$ref": "#/$defs/node"
        }
      },
      "additionalProperties": true
    },
    "extensions": {
      "type": "array"
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "Window",
            "MenuBar",
            "Menu",
            "MenuItem",
            "Toolbar",
            "Sidebar",
            "Content",
            "Section",
            "Stack",
            "Split",
            "Tabs",
            "List",
            "Detail",
            "Form",
            "Group",
            "Text",
            "Label",
            "Button",
            "Input",
            "Toggle",
            "Select",
            "Image",
            "Spacer",
            "Modal",
            "StatusBar"
          ]
        },
        "name": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "child": {
          "$ref": "#/$defs/node"
        },
        "platformOverrides": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  }
}
