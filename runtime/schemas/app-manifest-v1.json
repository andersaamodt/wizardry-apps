{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardry.example/schemas/app-manifest-v1.json",
  "title": "wizardry-apps manifest",
  "type": "object",
  "required": ["schemaVersion", "apps"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slug", "name", "production", "bundleIds"],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "production": {
            "type": "boolean"
          },
          "bundleIds": {
            "type": "object",
            "required": ["macos", "ios", "android"],
            "properties": {
              "macos": {
                "type": "string",
                "pattern": "^[A-Za-z0-9]+(\\.[A-Za-z0-9-]+)+$"
              },
              "ios": {
                "type": "string",
                "pattern": "^[A-Za-z0-9]+(\\.[A-Za-z0-9-]+)+$"
              },
              "android": {
                "type": "string",
                "pattern": "^[A-Za-z0-9]+(\\.[A-Za-z0-9-]+)+$"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
