#!/bin/sh

# Show the App Forge launcher menu.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: ./forge-menu

Shows a small App Forge menu using wizardry's menu spell.
USAGE
  exit 0
  ;;
esac

set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)

if command -v require-wizardry >/dev/null 2>&1; then
  require-wizardry || exit 1
elif [ -f "$HOME/.wizardry/spells/.imps/sys/invoke-wizardry" ]; then
  . "$HOME/.wizardry/spells/.imps/sys/invoke-wizardry"
else
  printf '%s\n' "forge-menu: wizardry is required for the menu command" >&2
  exit 1
fi

if command -v require >/dev/null 2>&1; then
  if ! require menu "App Forge needs wizardry's menu command."; then
    exit 1
  fi
elif ! command -v menu >/dev/null 2>&1; then
  printf '%s\n' "forge-menu: wizardry menu command not found" >&2
  exit 1
fi

case "${WIZARDRY_FORGE_MENU_INSTALLED-}" in
  0|1)
    is_installed=$WIZARDRY_FORGE_MENU_INSTALLED
    ;;
  *)
    is_installed=0
    if [ -x "$HOME/.local/bin/app-forge" ] || \
       [ -f "$HOME/.config/wizardry-apps/forge-root" ] || \
       [ -d "$HOME/Applications/App Forge.app" ] || \
       [ -d "/Applications/App Forge.app" ] || \
       [ -f "$HOME/.local/share/applications/app-forge.desktop" ]; then
      is_installed=1
    fi
    ;;
esac

if [ "$is_installed" -eq 1 ]; then
  menu "App Forge" \
    "Run Forge%\"$ROOT_DIR/spells/.imps/forge/run-forge\"" \
    "Uninstall Forge%\"$ROOT_DIR/spells/.imps/forge/uninstall-forge\"" \
    "Install Forge%\"$ROOT_DIR/spells/.imps/forge/install-forge\"" \
    "Exit%kill -TERM \$PPID"
else
  menu "App Forge" \
    "Install Forge%\"$ROOT_DIR/spells/.imps/forge/install-forge\"" \
    "Exit%kill -TERM \$PPID"
fi
