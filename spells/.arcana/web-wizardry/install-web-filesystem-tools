#!/bin/sh
# Install filesystem growth tools for Wizardry web workloads.
# Supports package-manager and source-based installation paths.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-filesystem-tools

Installs filesystem growth tools used by Wizardry and Headquarters.
USAGE
  exit 0
  ;;
esac

set -eu

require-wizardry || exit 1

exec install-filesystem-tools "$@"
