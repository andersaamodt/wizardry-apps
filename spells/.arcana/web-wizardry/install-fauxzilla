#!/bin/sh

# Install Fauxzilla through its repo checkout.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-fauxzilla

Clones or updates the Fauxzilla repo and runs its local install script.
USAGE
  exit 0
  ;;
esac

set -eu

repo_url=${FAUXZILLA_REPO_URL:-https://github.com/andersaamodt/fauxzilla.git}
repo_dir=${FAUXZILLA_REPO_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/fauxzilla/repo}

if [ "$#" -eq 0 ] && { [ -n "${HQ_SERVER_HOST-}" ] || [ -n "${HQ_SITE_DOMAIN-}" ]; }; then
  default_device_name=${FAUXZILLA_DEVICE_NAME:-${HQ_SITE_DOMAIN:-${HQ_SERVER_HOST:-Fauxzilla Hub}}}
  default_public_host=${HQ_SITE_DOMAIN:-${HQ_SERVER_HOST:-}}
  default_public_base_url=${FAUXZILLA_PUBLIC_BASE_URL:-}
  if [ -n "$default_public_host" ] && [ -z "$default_public_base_url" ]; then
    default_public_base_url=https://$default_public_host/fauxzilla
  fi
  if [ -n "$default_public_base_url" ]; then
    set -- --hub --device-name "$default_device_name" --public-base-url "$default_public_base_url"
  else
    set -- --hub --device-name "$default_device_name"
  fi
fi

if [ "$#" -eq 0 ] && [ -n "${HQ_HOST-}" ]; then
  default_device_name=${FAUXZILLA_DEVICE_NAME:-$HQ_HOST}
  default_public_base_url=${FAUXZILLA_PUBLIC_BASE_URL:-https://$HQ_HOST/fauxzilla}
  set -- --hub --device-name "$default_device_name" --public-base-url "$default_public_base_url"
fi

if [ -n "${HQ_UPLOADED_TREE_PATH-}" ] && [ -d "${HQ_UPLOADED_TREE_PATH-}" ]; then
  mkdir -p "$(dirname "$repo_dir")"
  rm -rf "$repo_dir"
  cp -R "$HQ_UPLOADED_TREE_PATH" "$repo_dir"
elif [ ! -d "$repo_dir/.git" ]; then
  command -v git >/dev/null 2>&1 || {
    printf '%s\n' 'install-fauxzilla: git is required to fetch Fauxzilla.' >&2
    exit 1
  }
  mkdir -p "$(dirname "$repo_dir")"
  git clone "$repo_url" "$repo_dir" >/dev/null
elif [ -z "${FAUXZILLA_SKIP_REPO_UPDATE-}" ]; then
  git -C "$repo_dir" pull --ff-only >/dev/null 2>&1 || true
fi

repo_spell=$repo_dir/scripts/fauxzilla-install
[ -f "$repo_spell" ] || {
  printf '%s\n' "install-fauxzilla: Fauxzilla repo checkout is missing $repo_spell." >&2
  exit 1
}

exec sh "$repo_spell" "$@"
