#!/bin/sh
# Remove filesystem growth tools installed for web workloads.
# Cleans package-manager and source-based installations.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-filesystem-tools

Removes filesystem growth tools used by Wizardry and Headquarters.
USAGE
  exit 0
  ;;
esac

set -eu

require-wizardry || exit 1

exec uninstall-filesystem-tools "$@"
