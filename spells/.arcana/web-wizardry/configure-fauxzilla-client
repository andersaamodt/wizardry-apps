#!/bin/sh

# Configure Firefox to install the Fauxzilla browser add-on.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: configure-fauxzilla-client [fauxzilla options]

Ensures the Fauxzilla repo checkout exists and forwards to Fauxzilla's browser
configuration helper, which writes Firefox enterprise policy for the local
Fauxzilla add-on.
USAGE
  exit 0
  ;;
esac

set -eu

repo_url=${FAUXZILLA_REPO_URL:-https://github.com/andersaamodt/fauxzilla.git}
repo_dir=${FAUXZILLA_REPO_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/fauxzilla/repo}

if [ -n "${HQ_UPLOADED_TREE_PATH-}" ] && [ -d "${HQ_UPLOADED_TREE_PATH-}" ]; then
  mkdir -p "$(dirname "$repo_dir")"
  rm -rf "$repo_dir"
  cp -R "$HQ_UPLOADED_TREE_PATH" "$repo_dir"
elif [ ! -d "$repo_dir/.git" ]; then
  command -v git >/dev/null 2>&1 || {
    printf '%s\n' 'configure-fauxzilla-client: git is required to fetch Fauxzilla.' >&2
    exit 1
  }
  mkdir -p "$(dirname "$repo_dir")"
  git clone "$repo_url" "$repo_dir" >/dev/null
elif [ -z "${FAUXZILLA_SKIP_REPO_UPDATE-}" ]; then
  git -C "$repo_dir" pull --ff-only >/dev/null 2>&1 || true
fi

repo_spell=$repo_dir/wizardry/configure-fauxzilla-client
[ -f "$repo_spell" ] || {
  printf '%s\n' "configure-fauxzilla-client: Fauxzilla repo checkout is missing $repo_spell." >&2
  exit 1
}

exec sh "$repo_spell" "$@"
