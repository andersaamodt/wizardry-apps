#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: icon-creation-status

Reports installation status for Forge icon creation tooling.
USAGE
  exit 0
  ;;
esac

set -eu

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
summary=$("$script_dir/check-imagemagick")
status=$(printf '%s\n' "$summary" | sed -n 's/^status=//p')

case "$status" in
  ok) printf '%s\n' 'installed' ;;
  bad|'') printf '%s\n' 'not installed' ;;
  *) printf '%s\n' "$status" ;;
esac
