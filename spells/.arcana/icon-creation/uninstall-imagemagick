#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-imagemagick

Removes ImageMagick when it was installed through a supported package manager
or a known local binary path.
USAGE
  exit 0
  ;;
esac

set -eu

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

say() {
  printf '%s\n' "$1"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

remove_known_binary() {
  removed_any=1
  for candidate in \
    "$(command -v magick 2>/dev/null || printf '')" \
    "${XDG_BIN_HOME:-$HOME/.local/bin}/magick" \
    "/usr/local/bin/magick" \
    "/opt/homebrew/bin/magick"
  do
    [ -n "$candidate" ] || continue
    [ -f "$candidate" ] || continue
    run_privileged rm -f "$candidate"
  done
}

removed=0

if has_cmd apt-get; then
  run_privileged env DEBIAN_FRONTEND=noninteractive apt-get remove -y imagemagick >/dev/null 2>&1 || true
  removed=1
elif has_cmd dnf; then
  run_privileged dnf remove -y ImageMagick >/dev/null 2>&1 || true
  removed=1
elif has_cmd pacman; then
  run_privileged pacman -R --noconfirm imagemagick >/dev/null 2>&1 || true
  removed=1
elif has_cmd brew; then
  brew uninstall imagemagick >/dev/null 2>&1 || true
  removed=1
fi

remove_known_binary || true

if has_cmd magick; then
  say "uninstall-imagemagick: ImageMagick is still present on PATH" >&2
  exit 1
fi

if [ "$removed" -eq 0 ]; then
  say "ImageMagick is not installed"
  exit 0
fi

say "Uninstalled ImageMagick"
