#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-imagemagick

Installs ImageMagick for Forge icon generation.
USAGE
  exit 0
  ;;
esac

set -eu

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

say() {
  printf '%s\n' "$1"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

if has_cmd magick; then
  say "ImageMagick is already installed"
  exit 0
fi

if has_cmd apt-get; then
  run_privileged apt-get update -y >/dev/null
  run_privileged env DEBIAN_FRONTEND=noninteractive apt-get install -y imagemagick >/dev/null
elif has_cmd dnf; then
  run_privileged dnf install -y ImageMagick >/dev/null
elif has_cmd pacman; then
  run_privileged pacman -Sy --noconfirm imagemagick >/dev/null
elif has_cmd brew; then
  brew install imagemagick >/dev/null
else
  say "install-imagemagick: no supported package manager found." >&2
  exit 1
fi

if has_cmd magick; then
  say "Installed ImageMagick"
  exit 0
fi

say "install-imagemagick: installation incomplete. Ensure magick is on PATH." >&2
exit 1
