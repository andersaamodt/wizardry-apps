#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: launch-app-forge [ROOT_DIR]

Launches App Forge for the specified wizardry-apps root.
Default root is the current repository.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/../../.." && pwd)
root=${1:-$repo_root}

exec "$repo_root/tools/forge/launch-forge" --root "$root"
