#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-app-forge [ROOT_DIR]

Installs user-local launchers for App Forge.
Default root is the current repository.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/../../.." && pwd)
root=${1:-$repo_root}

exec "$repo_root/tools/forge/install-forge" --root "$root"
