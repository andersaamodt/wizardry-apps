#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: wizardry-apps-web-admin

Administrative menu for wizardry-apps web pipelines.
USAGE
  exit 0
  ;;
esac

require-wizardry || exit 1

set -eu
. env-clear

if ! require menu "wizardry-apps-web-admin needs the 'menu' command."; then
  exit 1
fi

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/../../.." && pwd)
web_arcana_dir="$repo_root/spells/.arcana/web-wizardry"

while true; do
  exit_label=$(exit-label)
  menu "wizardry-apps web admin" \
    "Web component manager%\"$web_arcana_dir/web-wizardry-menu\"" \
    "Web status%\"$script_dir/wizardry-apps-status\" --section web" \
    "---" \
    "Adapter smoke tests%sh \"$repo_root/.tests/adapters/test-http-cgi.sh\"" \
    "${exit_label}%kill -TERM \$PPID" || menu_status=$?
  menu_status=${menu_status:-0}
  [ "$menu_status" -eq 130 ] && exit 0
done
