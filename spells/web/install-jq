#!/bin/sh
# Install jq for shell JSON processing.
# Prefers package-manager installation with safe fallbacks.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-jq

Ensures jq is installed for shell JSON processing.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

jq_say() {
  printf '%s\n' "$1"
}

jq_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

jq_run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if command -v run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if jq_has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

if jq_has_cmd jq; then
  jq_say "jq is already installed"
  exit 0
fi

if jq_has_cmd apt-get; then
  jq_run_privileged apt-get update -y >/dev/null
  jq_run_privileged env DEBIAN_FRONTEND=noninteractive apt-get install -y jq >/dev/null
elif jq_has_cmd dnf; then
  jq_run_privileged dnf install -y jq >/dev/null
elif jq_has_cmd brew; then
  brew install jq >/dev/null
else
  jq_say "install-jq: no supported package manager found." >&2
  exit 1
fi

if jq_has_cmd jq; then
  jq_say "Installed jq"
  exit 0
fi

jq_say "install-jq: installation incomplete. Ensure jq is on PATH." >&2
exit 1
