#!/bin/sh

# Enable the site daemon to start on boot.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: enable-site-daemon SITENAME

Enables the systemd/launchd daemon to start on boot for a site.

Example: enable-site-daemon mysite
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

site_name=${1-}
if [ -z "$site_name" ]; then
  die 2 "enable-site-daemon: SITENAME required"
fi
case "$site_name" in
  .|..|*[!a-zA-Z0-9._-]*)
    die 2 "enable-site-daemon: invalid site name"
    ;;
esac

web_root=${WEB_WIZARDRY_ROOT:-$HOME/sites}
sites_dir="$web_root"
site_dir="$sites_dir/$site_name"

if [ ! -d "$site_dir" ]; then
  die "enable-site-daemon: site '$site_name' not found"
fi

enable_run_priv() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return
  fi
  if has sudo; then
    if tty >/dev/null 2>&1; then
      sudo "$@" </dev/tty
    else
      sudo "$@"
    fi
    return
  fi
  die "enable-site-daemon: root or sudo is required"
}

unit="wizardry-site-${site_name}.service"
plist="${LAUNCHD_PLIST_DIR:-/Library/LaunchDaemons}/org.wizardry.web.${site_name}.plist"

enable_plist_bool_value() {
  key_name=$1
  awk -v key="$key_name" '
    $0 ~ "<key>" key "</key>" { found=1; next }
    found {
      if ($0 ~ /<true\/>/) { print "true"; exit }
      if ($0 ~ /<false\/>/) { print "false"; exit }
      if ($0 ~ /<key>/ || $0 ~ /<\/dict>/) { exit }
    }
  ' "$plist"
}

enable_set_plist_bool() {
  key_name=$1
  bool_value=$2
  tmp_file=$(temp-file enable-site-daemon)

  awk -v key="$key_name" -v val="$bool_value" '
    $0 ~ "<key>" key "</key>" {
      print
      if (getline nextline > 0) {
        if (nextline ~ /<true\/>|<false\/>/) {
          gsub(/<true\/>|<false\/>/, "<" val "/>", nextline)
          print nextline
          replaced=1
          next
        }
        print "  <" val "/>"
        print nextline
        replaced=1
        next
      }
      print "  <" val "/>"
      replaced=1
      next
    }
    $0 ~ "</dict>" && !replaced && !inserted {
      print "  <key>" key "</key>"
      print "  <" val "/>"
      inserted=1
    }
    { print }
    END {
      if (!replaced && !inserted) {
        print "  <key>" key "</key>"
        print "  <" val "/>"
      }
    }
  ' "$plist" > "$tmp_file"

  enable_run_priv cp "$tmp_file" "$plist"
  rm -f "$tmp_file"
}

if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && has launchctl; then
  # Check if daemon configuration exists
  if [ ! -f "$plist" ]; then
    die "enable-site-daemon: daemon not configured - run 'repair-site-daemon $site_name' first"
  fi
  
  label="org.wizardry.web.${site_name}"

  # Startup behavior on macOS is controlled by plist flags, not launchctl disable.
  # This keeps startup toggle independent from manual start/stop.
  enable_set_plist_bool RunAtLoad true
  enable_set_plist_bool KeepAlive true

  # Compatibility: clear stale disabled overrides from older implementations.
  enable_run_priv launchctl enable "system/$label" 2>/dev/null || true

  run_at_load=$(enable_plist_bool_value RunAtLoad || printf '')
  keep_alive=$(enable_plist_bool_value KeepAlive || printf '')
  if [ "$run_at_load" != "true" ] || [ "$keep_alive" != "true" ]; then
    die "enable-site-daemon: failed to enable daemon on startup for $site_name"
  fi
  
  success "Daemon enabled on startup for $site_name"
  exit 0
fi

if has systemctl; then
  # Check if daemon configuration exists
  daemon_artifact="${SERVICE_DIR:-/etc/systemd/system}/$unit"
  if [ ! -f "$daemon_artifact" ]; then
    die "enable-site-daemon: daemon not configured - run 'repair-site-daemon $site_name' first"
  fi
  
  enable_run_priv systemctl enable "$unit"
  success "Daemon enabled on startup for $site_name"
  exit 0
fi

die "enable-site-daemon: systemd or launchd is required"
