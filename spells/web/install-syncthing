#!/bin/sh
# Install Syncthing for content synchronization.
# Supports package-manager and binary installation paths.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-syncthing

Ensures Syncthing is installed for content synchronization.
USAGE
  exit 0
  ;;
esac

set -eu
syncthing_cmd=${SYNCTHING:-syncthing}
syncthing_curl=${CURL:-curl}
syncthing_xdg_bin_home=${XDG_BIN_HOME-}
. env-clear

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

syncthing_say() {
  printf '%s\n' "$1"
}

syncthing_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

syncthing_curl_cmd() {
  printf '%s\n' "$syncthing_curl"
}

syncthing_has_curl() {
  command -v "$(syncthing_curl_cmd)" >/dev/null 2>&1
}

syncthing_fetch_url() {
  "$(syncthing_curl_cmd)" -fsSL "$@"
}

syncthing_download_url_is_safe() {
  url=${1-}
  case "$url" in
    *[[:space:]]*)
      return 1
      ;;
  esac
  case "$url" in
    https://github.com/syncthing/syncthing/releases/download/*)
      return 0
      ;;
  esac
  return 1
}

install_syncthing_cli_supported() {
  command -v "$syncthing_cmd" >/dev/null 2>&1 || return 1
  "$syncthing_cmd" version 2>/dev/null | grep -Eiq '^syncthing v|^syncthing '
  "$syncthing_cmd" cli --help 2>/dev/null | grep -q 'Command line interface'
}

syncthing_run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if command -v run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if syncthing_has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

install_syncthing_target_bin_dir() {
  if [ -n "$syncthing_xdg_bin_home" ]; then
    printf '%s\n' "$syncthing_xdg_bin_home"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' /usr/local/bin
    return 0
  fi
  if syncthing_has_cmd sudo || command -v run_sudo_cmd >/dev/null 2>&1; then
    printf '%s\n' /usr/local/bin
    return 0
  fi
  printf '%s\n' "${XDG_BIN_HOME:-$HOME/.local/bin}"
}

install_binary() {
  source_path=$1
  target_bin_dir=$(install_syncthing_target_bin_dir)
  syncthing_run_privileged install -d -m 755 "$target_bin_dir"
  syncthing_run_privileged install -m 755 "$source_path" "$target_bin_dir/syncthing"
}

install_systemd_override() {
  [ -f /lib/systemd/system/syncthing@.service ] || \
    [ -f /usr/lib/systemd/system/syncthing@.service ] || return 0
  target_bin_dir=$(install_syncthing_target_bin_dir)
  target_bin="$target_bin_dir/syncthing"
  [ -x "$target_bin" ] || return 0
  override_dir=/etc/systemd/system/syncthing@.service.d
  syncthing_run_privileged install -d -m 755 "$override_dir"
  tmp_override=$(mktemp "${TMPDIR:-/tmp}/syncthing-override.XXXXXX")
  cat > "$tmp_override" <<EOF
[Service]
ExecStart=
ExecStart=$target_bin serve --no-browser --no-restart --logflags=0
EOF
  syncthing_run_privileged install -m 644 "$tmp_override" "$override_dir/override.conf"
  rm -f "$tmp_override"
  if syncthing_has_cmd systemctl; then
    syncthing_run_privileged systemctl daemon-reload >/dev/null 2>&1 || true
  fi
}

install_syncthing_platform_suffix() {
  os_name=$(uname -s 2>/dev/null || printf '')
  arch_name=$(uname -m 2>/dev/null || printf '')
  case "$os_name" in
    Linux) platform_os=linux ;;
    Darwin) platform_os=macos ;;
    FreeBSD) platform_os=freebsd ;;
    *)
      return 1
      ;;
  esac
  case "$platform_os:$arch_name" in
    linux:x86_64|linux:amd64) platform_arch=amd64 ;;
    linux:arm64|linux:aarch64) platform_arch=arm64 ;;
    linux:riscv64) platform_arch=riscv64 ;;
    macos:arm64|macos:aarch64) platform_arch=universal ;;
    macos:x86_64|macos:amd64) platform_arch=universal ;;
    freebsd:x86_64|freebsd:amd64) platform_arch=amd64 ;;
    *)
      return 1
      ;;
  esac
  printf '%s-%s\n' "$platform_os" "$platform_arch"
}

install_syncthing_release_binary() {
  syncthing_has_curl || return 1
  syncthing_has_cmd tar || return 1
  platform=$(install_syncthing_platform_suffix 2>/dev/null || true)
  [ -n "$platform" ] || return 1

  release_json=$(
    syncthing_fetch_url \
      https://api.github.com/repos/syncthing/syncthing/releases/latest \
      2>/dev/null || true
  )
  [ -n "$release_json" ] || return 1
  release_json_one_line=$(printf '%s' "$release_json" | tr '\n' ' ')
  case "$platform" in
    macos-universal)
      asset_suffix="syncthing-macos-universal-v"
      asset_ext=".zip"
      ;;
    *)
      asset_suffix="syncthing-${platform}-v"
      asset_ext=".tar.gz"
      ;;
  esac
  download_url=$(
    printf '%s\n' "$release_json_one_line" |
      sed -n "s/.*\"browser_download_url\":[[:space:]]*\"\\([^\"]*${asset_suffix}[^\"]*${asset_ext}\\)\".*/\\1/p" |
      head -n 1
  )
  [ -n "$download_url" ] || return 1
  syncthing_download_url_is_safe "$download_url" || return 1

  tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/syncthing-release.XXXXXX")
  archive_path="$tmp_dir/archive${asset_ext}"
  syncthing_fetch_url "$download_url" -o "$archive_path" || {
    rm -rf "$tmp_dir"
    return 1
  }
  case "$asset_ext" in
    .tar.gz)
      tar -xzf "$archive_path" -C "$tmp_dir" || {
        rm -rf "$tmp_dir"
        return 1
      }
      ;;
    .zip)
      syncthing_has_cmd unzip || {
        rm -rf "$tmp_dir"
        return 1
      }
      unzip -q "$archive_path" -d "$tmp_dir" || {
        rm -rf "$tmp_dir"
        return 1
      }
      ;;
  esac
  binary_path=$(
    find "$tmp_dir" -mindepth 2 -maxdepth 2 -type f -path '*/syncthing' -perm -111 | head -n 1
  )
  [ -n "$binary_path" ] || {
    rm -rf "$tmp_dir"
    return 1
  }
  install_binary "$binary_path"
  rm -rf "$tmp_dir"
  install_syncthing_cli_supported
}

if install_syncthing_cli_supported; then
  install_systemd_override
  syncthing_say "Syncthing is already installed"
  exit 0
fi

install_syncthing_release_binary >/dev/null 2>&1 || true

if install_syncthing_cli_supported; then
  install_systemd_override
  syncthing_say "Installed Syncthing"
  exit 0
fi

if syncthing_has_cmd apt-get; then
  syncthing_run_privileged apt-get update -y >/dev/null
  syncthing_run_privileged env DEBIAN_FRONTEND=noninteractive \
    apt-get install -y syncthing >/dev/null
elif syncthing_has_cmd dnf; then
  syncthing_run_privileged dnf install -y syncthing >/dev/null
elif syncthing_has_cmd brew; then
  brew install syncthing >/dev/null
else
  syncthing_say "install-syncthing: no supported package manager found." >&2
  exit 1
fi

install_syncthing_release_binary >/dev/null 2>&1 || true

if install_syncthing_cli_supported; then
  install_systemd_override
  syncthing_say "Installed Syncthing"
  exit 0
fi

syncthing_say \
  "install-syncthing: installation incomplete. Ensure a modern Syncthing with CLI support is on PATH." >&2
exit 1
