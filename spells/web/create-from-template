#!/bin/sh

# Create a site from a template.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: create-from-template SITENAME TEMPLATE

Creates a new site by copying an available template source.

Example: create-from-template mysite demo
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

template_source_candidates() {
  wizardry_root=${WIZARDRY_DIR:-$HOME/.wizardry}
  wizardry_parent=$(dirname "$wizardry_root")
  printf '%s\n' \
    "$wizardry_root/web" \
    "$wizardry_root/spells/web" \
    "$wizardry_parent/git/wizardry-apps/web" \
    "$HOME/git/wizardry-apps/web"
}

external_template_candidates() {
  template_name=$1
  wizardry_root=${WIZARDRY_DIR:-$HOME/.wizardry}
  wizardry_parent=$(dirname "$wizardry_root")

  case "$template_name" in
    blog)
      printf '%s\n' \
        "$wizardry_parent/git/blog-template" \
        "$HOME/git/blog-template" \
        "$wizardry_parent/git/nostr-blog" \
        "$HOME/git/nostr-blog"
      ;;
    unix-settings)
      printf '%s\n' \
        "$wizardry_parent/git/unix-settings/hosted-web" \
        "$HOME/git/unix-settings/hosted-web"
      ;;
    artificer)
      printf '%s\n' \
        "$wizardry_parent/git/artificer/hosted-web" \
        "$HOME/git/artificer/hosted-web"
      ;;
  esac
}

create_template_name_is_safe() {
  case "${1-}" in
    .|..|''|*[!a-zA-Z0-9._-]*)
      return 1
      ;;
  esac
  return 0
}

resolve_template_dir() {
  template_name=$1
  create_template_name_is_safe "$template_name" || return 1
  template_candidates=$(template_source_candidates)
  while IFS= read -r candidate || [ -n "$candidate" ]; do
    if [ -d "$candidate/$template_name" ]; then
      printf '%s\n' "$candidate/$template_name"
      return 0
    fi
  done <<EOF
$template_candidates
EOF
  template_candidates=$(external_template_candidates "$template_name")
  while IFS= read -r candidate || [ -n "$candidate" ]; do
    if [ -d "$candidate/pages" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done <<EOF
$template_candidates
EOF
  return 1
}

resolve_shared_theme_dir() {
  theme_candidates=$(template_source_candidates)
  while IFS= read -r candidate || [ -n "$candidate" ]; do
    if [ -d "$candidate/.themes" ]; then
      printf '%s\n' "$candidate/.themes"
      return 0
    fi
  done <<EOF
$theme_candidates
EOF
  return 1
}

list_available_templates() {
  for template_name in demo blog unix-settings artificer; do
    if resolve_template_dir "$template_name" >/dev/null 2>&1; then
      printf '%s\n' "$template_name"
    fi
  done
}

case "${1-}" in
  --list-templates)
    list_available_templates
    exit 0
    ;;
  --resolve-template-dir)
    if [ -z "${2-}" ]; then
      die 2 "create-from-template: TEMPLATE required for --resolve-template-dir"
    fi
    if ! create_template_name_is_safe "$2"; then
      die 2 "create-from-template: invalid template name"
    fi
    resolve_template_dir "$2" || exit 1
    exit 0
    ;;
esac

site_name=${1-}
template=${2-}

if [ -z "$site_name" ]; then
  die 2 "create-from-template: SITENAME required"
fi
case "$site_name" in
  .|..|*[!a-zA-Z0-9._-]*)
    die 2 "create-from-template: invalid site name"
    ;;
esac

if [ -z "$template" ]; then
  die 2 "create-from-template: TEMPLATE required"
fi
if ! create_template_name_is_safe "$template"; then
  die 2 "create-from-template: invalid template name"
fi

web_root=${WEB_WIZARDRY_ROOT:-$HOME/sites}
sites_dir="$web_root"
site_dir="$sites_dir/$site_name"

# Check if site already exists
if [ -d "$site_dir" ]; then
  die "create-from-template: site '$site_name' already exists"
fi

template_dir=$(resolve_template_dir "$template" 2>/dev/null || printf '')
shared_theme_dir=$(resolve_shared_theme_dir 2>/dev/null || printf '')

if [ ! -d "$template_dir" ]; then
  die "create-from-template: template '$template' not found"
fi

step "Creating site '$site_name' from template '$template'..."

# Copy template to site directory
mkdir -p "$site_dir"
cp -r "$template_dir"/* "$site_dir/"

# Rename to match expected structure
if [ -d "$site_dir/pages" ]; then
  mkdir -p "$site_dir/site"
  mv "$site_dir/pages" "$site_dir/site/"
fi

if [ -d "$site_dir/static" ]; then
  [ ! -d "$site_dir/site" ] && mkdir -p "$site_dir/site"
  mv "$site_dir/static" "$site_dir/site/"
fi

if [ -d "$site_dir/includes" ]; then
  [ ! -d "$site_dir/site" ] && mkdir -p "$site_dir/site"
  mv "$site_dir/includes" "$site_dir/site/"
fi

# Sync shared theme catalog into every site template.
if [ -d "$shared_theme_dir" ]; then
  mkdir -p "$site_dir/site/static/themes"
  cp -f "$shared_theme_dir"/*.css "$site_dir/site/static/themes/" 2>/dev/null || true
fi

if [ -f "$template_dir/wizardry-server-requirements.conf" ]; then
  cp "$template_dir/wizardry-server-requirements.conf" "$site_dir/"
fi

if [ -f "$template_dir/wizardry-content-layout.conf" ]; then
  cp "$template_dir/wizardry-content-layout.conf" "$site_dir/"
fi

# Create additional required directories
mkdir -p "$site_dir/site/uploads"
mkdir -p "$site_dir/build"
if [ "$template" = "blog" ]; then
  mkdir -p "$site_dir/site/nostr/state" "$site_dir/site/nostr/events" "$site_dir/site/nostr/derived"
  : > "$site_dir/site/nostr/state/authors.txt"
  : > "$site_dir/site/nostr/state/relays.txt"
  : > "$site_dir/site/nostr/state/blocklist.txt"
  : > "$site_dir/site/nostr/state/hidden_posts.txt"
fi

# Create site config
cat > "$site_dir/site.conf" <<EOF
# Site configuration for $site_name
site-name=$site_name
site-user=
template=$template
port=8080
domain=localhost
https=false
EOF

if [ "$template" = "blog" ]; then
  cat >> "$site_dir/site.conf" <<'EOF'
nostr_bridge_enabled=false
new_users_are_admins=true
EOF
fi

cat > "$site_dir/site.allowlist" <<EOF
# List additional absolute paths this site may access.
# One path per line. Lines starting with # are ignored.
EOF

if [ "${WIZARDRY_TEST_HELPERS_ONLY:-0}" = "1" ]; then
  info "Skipping fix-site-security in test mode"
else
  step "Securing site directories for $site_name"
  fix-site-security "$site_name"
fi

success "Site '$site_name' created from template '$template'"
info "Site directory: $site_dir"
info ""
info "Next steps:"
info "  1. Build: web-wizardry build $site_name"
info "  2. Serve: web-wizardry serve $site_name"
info "  3. Visit: http://localhost:8080"
