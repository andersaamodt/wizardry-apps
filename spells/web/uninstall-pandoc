#!/bin/sh
# Remove pandoc when installed by supported methods.
# Cleans package-manager and downloaded binary installations.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-pandoc

Removes pandoc when it was installed through a supported package manager.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

pandoc_uninstall_say() {
  printf '%s\n' "$1"
}

pandoc_uninstall_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

pandoc_uninstall_run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if command -v run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if pandoc_uninstall_has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

removed=0

if pandoc_uninstall_has_cmd apt-get; then
  pandoc_uninstall_run_privileged env DEBIAN_FRONTEND=noninteractive \
    apt-get remove -y pandoc >/dev/null 2>&1 || true
  removed=1
elif pandoc_uninstall_has_cmd dnf; then
  pandoc_uninstall_run_privileged dnf remove -y pandoc >/dev/null 2>&1 || true
  removed=1
elif pandoc_uninstall_has_cmd brew; then
  brew uninstall pandoc >/dev/null 2>&1 || true
  removed=1
fi

if pandoc_uninstall_has_cmd pandoc; then
  pandoc_uninstall_say "uninstall-pandoc: pandoc is still present on PATH" >&2
  exit 1
fi

if [ "$removed" -eq 0 ]; then
  pandoc_uninstall_say "pandoc is not installed"
  exit 0
fi

pandoc_uninstall_say "Uninstalled pandoc"
