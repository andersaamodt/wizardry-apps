#!/bin/sh

# Uninstall BTCPay Server runtime and local deployment files.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-btcpay

Stops BTCPay Server containers and removes local deployment files.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
arcana_uninstall="$script_dir/../.arcana/btcpay/uninstall-btcpay-arcana"

if [ ! -x "$arcana_uninstall" ]; then
  printf '%s\n' 'uninstall-btcpay: BTCPay uninstall spell is unavailable.' >&2
  exit 1
fi

"$arcana_uninstall" "$@"
