#!/bin/sh
# Install SuperCollider from the system package manager or trusted macOS release assets.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-supercollider

Ensures SuperCollider is installed.
USAGE
  exit 0
  ;;
esac

set -eu

supercollider_curl=${CURL:-curl}
supercollider_sclang=${SCLANG:-sclang}
supercollider_app_path=${SUPERCOLLIDER_APP_PATH-}

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

supercollider_say() {
  printf '%s\n' "$1"
}

supercollider_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

supercollider_curl_cmd() {
  printf '%s\n' "$supercollider_curl"
}

supercollider_has_curl() {
  command -v "$(supercollider_curl_cmd)" >/dev/null 2>&1
}

supercollider_fetch_url() {
  "$(supercollider_curl_cmd)" -fsSL "$@"
}

download_url_is_safe() {
  url=${1-}
  case "$url" in
    *[[:space:]]*)
      return 1
      ;;
  esac
  case "$url" in
    https://github.com/supercollider/supercollider/releases/download/*)
      return 0
      ;;
  esac
  return 1
}

supercollider_run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if command -v run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if supercollider_has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

supercollider_install_target_bin_dir() {
  if [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' /usr/local/bin
    return 0
  fi
  if supercollider_has_cmd sudo || command -v run_sudo_cmd >/dev/null 2>&1; then
    printf '%s\n' /usr/local/bin
    return 0
  fi
  printf '%s\n' "${XDG_BIN_HOME:-$HOME/.local/bin}"
}

supercollider_installed() {
  if supercollider_has_cmd "$supercollider_sclang"; then
    return 0
  fi
  case "$(uname -s 2>/dev/null || printf '')" in
    Darwin)
      if [ -n "$supercollider_app_path" ]; then
        [ -d "$supercollider_app_path" ]
      else
        [ -d /Applications/SuperCollider.app ] ||
          [ -d "$HOME/Applications/SuperCollider.app" ]
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

release_json_latest() {
  supercollider_has_curl || return 1
  release_url=https://api.github.com/repos/supercollider/supercollider/releases/latest
  supercollider_fetch_url "$release_url" 2>/dev/null || return 1
}

install_macos_cli_links() {
  app_path=$1
  target_bin_dir=$(supercollider_install_target_bin_dir)
  supercollider_run_privileged install -d -m 755 "$target_bin_dir"
  for bin_name in sclang scsynth supernova; do
    case "$bin_name" in
      sclang) source_path="$app_path/Contents/MacOS/sclang" ;;
      *) source_path="$app_path/Contents/Resources/$bin_name" ;;
    esac
    [ -x "$source_path" ] || continue
    supercollider_run_privileged ln -sf "$source_path" "$target_bin_dir/$bin_name" || true
  done
}

install_supercollider_macos_release() {
  supercollider_has_curl || return 1
  supercollider_has_cmd hdiutil || return 1

  release_json=$(release_json_latest) || return 1
  release_json_one_line=$(printf '%s' "$release_json" | tr '\n' ' ')
  download_url=$(
    printf '%s\n' "$release_json_one_line" |
      sed -n 's/.*"browser_download_url":[[:space:]]*"\([^"]*SuperCollider-[^"]*-macOS-universal\.dmg\)".*/\1/p' |
      head -n 1
  )
  [ -n "$download_url" ] || return 1
  download_url_is_safe "$download_url" || return 1

  tmp_root=$(mktemp -d "${TMPDIR:-/tmp}/supercollider-release.XXXXXX")
  archive_path="$tmp_root/SuperCollider.dmg"
  mount_dir="$tmp_root/mount"
  stage_root="$tmp_root/stage"
  stage_bundle="$stage_root/SuperCollider.app"
  target_parent="$HOME/Applications"
  target_bundle="$target_parent/SuperCollider.app"
  backup_bundle=
  mounted=0

  if [ -n "$supercollider_app_path" ]; then
    target_bundle=$supercollider_app_path
    target_parent=$(dirname "$target_bundle")
  elif [ "$(id -u)" -eq 0 ] || supercollider_has_cmd sudo ||
    command -v run_sudo_cmd >/dev/null 2>&1; then
    target_parent=/Applications
    target_bundle="$target_parent/SuperCollider.app"
  fi

  mkdir -p "$mount_dir" "$stage_root"
  supercollider_fetch_url "$download_url" -o "$archive_path" || {
    rm -rf "$tmp_root"
    return 1
  }

  hdiutil attach -nobrowse -quiet -mountpoint "$mount_dir" "$archive_path" >/dev/null 2>&1 || {
    rm -rf "$tmp_root"
    return 1
  }
  mounted=1

  source_bundle=$(find "$mount_dir" -maxdepth 2 -type d -name 'SuperCollider.app' | head -n 1)
  [ -n "$source_bundle" ] || {
    hdiutil detach -quiet "$mount_dir" >/dev/null 2>&1 || true
    rm -rf "$tmp_root"
    return 1
  }

  if supercollider_has_cmd ditto; then
    ditto "$source_bundle" "$stage_bundle" || {
      hdiutil detach -quiet "$mount_dir" >/dev/null 2>&1 || true
      rm -rf "$tmp_root"
      return 1
    }
  else
    cp -R "$source_bundle" "$stage_bundle" || {
      hdiutil detach -quiet "$mount_dir" >/dev/null 2>&1 || true
      rm -rf "$tmp_root"
      return 1
    }
  fi

  hdiutil detach -quiet "$mount_dir" >/dev/null 2>&1 || true
  mounted=0

  supercollider_run_privileged mkdir -p "$target_parent"
  if [ -d "$target_bundle" ]; then
    backup_bundle="$target_parent/.SuperCollider.app.wizardry-old.$$"
    supercollider_run_privileged rm -rf "$backup_bundle"
    supercollider_run_privileged mv "$target_bundle" "$backup_bundle" || {
      rm -rf "$tmp_root"
      return 1
    }
  fi
  supercollider_run_privileged mv "$stage_bundle" "$target_bundle" || {
    if [ -n "$backup_bundle" ] && [ -d "$backup_bundle" ]; then
      supercollider_run_privileged mv "$backup_bundle" "$target_bundle" >/dev/null 2>&1 || true
    fi
    rm -rf "$tmp_root"
    return 1
  }
  if [ -n "$backup_bundle" ]; then
    supercollider_run_privileged rm -rf "$backup_bundle" >/dev/null 2>&1 || true
  fi
  install_macos_cli_links "$target_bundle"

  if [ "$mounted" -eq 1 ]; then
    hdiutil detach -quiet "$mount_dir" >/dev/null 2>&1 || true
  fi
  rm -rf "$tmp_root"
  supercollider_installed
}

install_supercollider_unix_pkg() {
  if supercollider_has_cmd apt-get; then
    supercollider_run_privileged apt-get update -y >/dev/null
    supercollider_run_privileged env DEBIAN_FRONTEND=noninteractive apt-get install -y supercollider >/dev/null
    return 0
  fi
  if supercollider_has_cmd dnf; then
    supercollider_run_privileged dnf install -y supercollider >/dev/null
    return 0
  fi
  if supercollider_has_cmd pacman; then
    supercollider_run_privileged pacman -Sy --noconfirm supercollider >/dev/null
    return 0
  fi
  if supercollider_has_cmd zypper; then
    supercollider_run_privileged zypper --non-interactive install supercollider >/dev/null
    return 0
  fi
  if supercollider_has_cmd apk; then
    supercollider_run_privileged apk add supercollider >/dev/null
    return 0
  fi
  if supercollider_has_cmd nix-env; then
    nix-env -iA nixpkgs.supercollider >/dev/null
    return 0
  fi
  if supercollider_has_cmd pkg; then
    supercollider_run_privileged pkg install -y supercollider >/dev/null
    return 0
  fi
  if supercollider_has_cmd pkg_add; then
    supercollider_run_privileged pkg_add supercollider >/dev/null
    return 0
  fi
  if supercollider_has_cmd brew; then
    brew install --cask supercollider >/dev/null
    return 0
  fi
  return 1
}

if supercollider_installed; then
  supercollider_say "SuperCollider is already installed"
  exit 0
fi

case "$(uname -s 2>/dev/null || printf '')" in
  Darwin)
    install_supercollider_macos_release >/dev/null 2>&1 || true
    if supercollider_installed; then
      supercollider_say "Installed SuperCollider"
      exit 0
    fi
    if supercollider_has_cmd brew; then
      brew install --cask supercollider >/dev/null
    else
      supercollider_say "install-supercollider: automatic macOS install failed." >&2
      exit 1
    fi
    ;;
  Linux|FreeBSD|OpenBSD)
    if ! install_supercollider_unix_pkg; then
      supercollider_say "install-supercollider: no supported package manager found." >&2
      exit 1
    fi
    ;;
  *)
    supercollider_say "install-supercollider: unsupported host." >&2
    exit 1
    ;;
esac

if supercollider_installed; then
  supercollider_say "Installed SuperCollider"
  exit 0
fi

supercollider_say "install-supercollider: installation incomplete." >&2
supercollider_say "Ensure SuperCollider is available on PATH." >&2
exit 1
