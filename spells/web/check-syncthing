#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: check-syncthing

Checks whether Syncthing is available for content synchronization.
USAGE
  exit 0
  ;;
esac

set -eu

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

if command -v syncthing >/dev/null 2>&1; then
  printf 'status=ok\n'
  printf 'summary=%s\n' 'Syncthing is available on PATH.'
  exit 0
fi

printf 'status=bad\n'
printf 'summary=%s\n' 'Syncthing is not installed.'
exit 0
