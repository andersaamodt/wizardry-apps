#!/bin/sh

# Uninstall server-side nostril tooling.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-nostril

Removes the nostril CLI and verifier dependency used for server-side Nostr signature verification.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

removed_any=0

for path in "$(command -v nostril 2>/dev/null || printf '')" \
            "${XDG_BIN_HOME:-$HOME/.local/bin}/nostril" \
            "/usr/local/bin/nostril" \
            "/opt/homebrew/bin/nostril"; do
  [ -n "$path" ] || continue
  if [ -f "$path" ]; then
    step "Removing nostril binary at $path"
    rm -f "$path"
    removed_any=1
  fi
done

for qpath in "${XDG_BIN_HOME:-$HOME/.local/bin}/nostril-query" \
             "/usr/local/bin/nostril-query" \
             "/opt/homebrew/bin/nostril-query"; do
  [ -f "$qpath" ] || continue
  rm -f "$qpath"
done

if has brew; then
  if brew list --formula nak >/dev/null 2>&1; then
    step "Removing nak verifier via Homebrew..."
    brew uninstall nak >/dev/null 2>&1 || true
    removed_any=1
  fi
fi

if has nostril || has nak; then
  die "uninstall-nostril: nostril tooling is still present on PATH"
fi

if [ "$removed_any" -eq 0 ]; then
  info "nostril tooling is not installed"
  exit 0
fi

success "Uninstalled nostril tooling"
