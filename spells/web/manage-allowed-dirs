#!/bin/sh

# Manage allowlisted directories for a wizardry site.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: manage-allowed-dirs SITENAME

Manage the per-site allowlist of directories that a site may access.

Example: web-manage-allowed-dirs mysite
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear
. colors

site_name=${1-}
if [ -z "$site_name" ]; then
  die 2 "manage-allowed-dirs: SITENAME required"
fi
case "$site_name" in
  .|..|*[!a-zA-Z0-9._-]*)
    die 2 "manage-allowed-dirs: invalid site name"
    ;;
esac

web_root=${WEB_WIZARDRY_ROOT:-$HOME/sites}
sites_dir="$web_root"
site_dir="$sites_dir/$site_name"
allowlist_file="$site_dir/site.allowlist"

if [ ! -d "$site_dir" ]; then
  die "manage-allowed-dirs: site '$site_name' not found"
fi

site_user_default="ww_$(printf '%s' "$site_name" | tr 'A-Z' 'a-z' | tr '.-' '__')"
site_user=$(config-get "$site_dir/site.conf" site-user 2>/dev/null || printf '')
[ -z "$site_user" ] && site_user="$site_user_default"
case "$site_user" in
  ''|.|..|-*|*[!a-zA-Z0-9._-]*)
    die 2 "manage-allowed-dirs: invalid site-user in site.conf"
    ;;
esac
if [ -n "$site_user" ] && [ "$(id -un)" != "$site_user" ] && [ -z "${WIZARDRY_SITE_USER_REEXEC-}" ]; then
  if has sudo; then
    exec sudo -u "$site_user" -- env WIZARDRY_SITE_USER_REEXEC=1 "$0" "$site_name" "$@"
  fi
fi

manage_allowed_dirs_shell_quote() {
  printf "'"
  printf '%s' "$1" | sed "s/'/'\\\\''/g"
  printf "'"
}

manage_allowed_dirs_canonical_dir() {
  (CDPATH= cd -- "$1" 2>/dev/null && pwd -P)
}

validate_allowlist_dir() {
  allow_path=$1
  if [ -z "$allow_path" ]; then
    warn "No path entered"
    return 1
  fi
  case "$allow_path" in
    *"$(printf '\r')"*)
      warn "Path must not contain control characters"
      return 1
      ;;
    /*) ;;
    *)
      warn "Path must be absolute"
      return 1
      ;;
  esac
  if [ ! -d "$allow_path" ]; then
    warn "Path must be an existing directory: $allow_path"
    return 1
  fi

  allow_real=$(manage_allowed_dirs_canonical_dir "$allow_path") || {
    warn "Path cannot be resolved: $allow_path"
    return 1
  }
  sites_real=$(manage_allowed_dirs_canonical_dir "$sites_dir") || sites_real=$sites_dir
  site_real=$(manage_allowed_dirs_canonical_dir "$site_dir") || site_real=$site_dir
  sitedata_root_real=$(manage_allowed_dirs_canonical_dir "$sites_dir/.sitedata" 2>/dev/null || printf '')
  home_real=
  if [ -n "${HOME-}" ]; then
    home_real=$(manage_allowed_dirs_canonical_dir "$HOME" 2>/dev/null || printf '')
  fi

  case "$allow_real" in
    /)
      warn "Path is too broad to allowlist: $allow_path"
      return 1
      ;;
    "$sites_real"|"$site_real"|"$site_real"/*)
      warn "Path is managed by this site already: $allow_path"
      return 1
      ;;
  esac
  if [ -n "$sitedata_root_real" ]; then
    case "$allow_real" in
      "$sitedata_root_real"|"$sitedata_root_real"/*)
        warn "Path is managed site data: $allow_path"
        return 1
        ;;
    esac
  fi
  if [ -n "$home_real" ] && [ "$allow_real" = "$home_real" ]; then
    warn "Path is too broad to allowlist: $allow_path"
    return 1
  fi
  return 0
}

ensure_allowlist_file() {
  if [ -f "$allowlist_file" ]; then
    return 0
  fi
  cat > "$allowlist_file" <<'EOF'
# List additional absolute paths this site may access.
# One path per line. Lines starting with # are ignored.
EOF
}

list_allowlist_entries() {
  if [ ! -f "$allowlist_file" ]; then
    return 0
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line=$(printf '%s' "$line" | sed 's/#.*$//' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ -z "$line" ] && continue
    printf '%s\n' "$line"
  done < "$allowlist_file"
}

add_allowlist_entry() {
  printf 'Enter absolute path to allow: '
  read -r new_path || return 1
  new_path=$(printf '%s' "$new_path" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
  if ! validate_allowlist_dir "$new_path"; then
    return 1
  fi
  if list_allowlist_entries | grep -Fx "$new_path" >/dev/null 2>&1; then
    warn "Path already allowlisted"
    return 1
  fi
  printf '%s\n' "$new_path" >> "$allowlist_file"
  success "Allowlisted: $new_path"
  fix-site-security "$site_name"
}

remove_allowlist_entry() {
  remove_path=$1
  printf 'Remove %s? [y/N] ' "$remove_path"
  read -r response || return 1
  case "$response" in
    [yY]|[yY][eE][sS])
      ;;
    *)
      info "Cancelled"
      return 0
      ;;
  esac

  temp_file=$(temp-file allowlist)
  if [ -f "$allowlist_file" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
      trimmed=$(printf '%s' "$line" | sed 's/#.*$//' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
      if [ -n "$trimmed" ] && [ "$trimmed" = "$remove_path" ]; then
        continue
      fi
      printf '%s\n' "$line" >> "$temp_file"
    done < "$allowlist_file"
    mv "$temp_file" "$allowlist_file"
  else
    cleanup-file "$temp_file"
  fi
  success "Removed: $remove_path"
  fix-site-security "$site_name"
}

ensure_allowlist_file

while true; do
  entries=$(list_allowlist_entries || true)
  if [ -z "$entries" ]; then
    printf 'There are no items on the allowlist for site %s.\n' "$site_name"
    printf 'Add one now? (Sites already have access to their sites and .sitedata folder by default.) [y/N] '
    read -r response || exit 1
    case "$response" in
      [yY]|[yY][eE][sS])
        add_allowlist_entry || true
        ;;
      *)
        exit 0
        ;;
    esac
    continue
  fi

  set -- "Add allowed dir%add_allowlist_entry" "---"
  while IFS= read -r entry; do
    quoted_entry=$(manage_allowed_dirs_shell_quote "$entry")
    set -- "$@" "$entry%remove_allowlist_entry $quoted_entry"
  done <<EOF
$entries
EOF
  set -- "$@" "---" "$(exit-label)%kill -TERM \$PPID"
  menu "${BOLD}${CYAN}Allowed dirs: $site_name${RESET}" "$@" || menu_status=$?
  menu_status=${menu_status:-0}
  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi
done
