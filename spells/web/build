#!/bin/sh

# Build a wizardry web site (Markdown to HTML with Pandoc).

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: build SITENAME [--full] [--watch]

Builds a website by converting Markdown to HTML with Pandoc.

Options:
  --full    Full rebuild (ignore mtime)
  --watch   Watch mode (rebuild on changes)

Default is incremental rebuild using mtime.

Example: web-build mysite
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

WIZARDRY_DIR=${WIZARDRY_DIR:-$HOME/.wizardry}

site_name=${1-}
if [ -z "$site_name" ]; then
  die 2 "build: SITENAME required"
fi

case "$site_name" in
  .|..|*[!a-zA-Z0-9._-]*)
    die 2 "build: invalid site name"
    ;;
esac

# Parse options
full_rebuild=0
watch_mode=0
shift
while [ $# -gt 0 ]; do
  case "$1" in
    --full) full_rebuild=1; shift ;;
    --watch) watch_mode=1; shift ;;
    *) die 2 "build: unknown option '$1'" ;;
  esac
done

web_root=${WEB_WIZARDRY_ROOT:-$HOME/sites}
sites_dir="$web_root"
site_dir="$sites_dir/$site_name"
site_data_dir="$sites_dir/.sitedata/$site_name"

if [ ! -d "$site_dir" ]; then
  die "build: site '$site_name' not found"
fi

if ! has pandoc; then
  die "build: pandoc is required but not installed"
fi

extract_front_matter_value() {
  file=$1
  key=$2
  awk -v key="$key" '
    BEGIN { in_fm = 0 }
    /^---$/ {
      if (in_fm == 0) {
        in_fm = 1
        next
      }
      exit
    }
    in_fm == 1 {
      if (index($0, key ":") == 1) {
        sub(/^[^:]*:[[:space:]]*/, "", $0)
        gsub(/^"|"$/, "", $0)
        print $0
        exit
      }
    }
  ' "$file"
}

extract_markdown_body() {
  file=$1
  awk '
    BEGIN { d = 0 }
    /^---$/ { d++; next }
    d >= 2 { print }
    d == 0 { print }
  ' "$file"
}

strip_dynamic_title_block() {
  file=$1
  [ -f "$file" ] || return 0
  if ! grep -Eq 'id="(blog-page-root|nip23-page-root|public-ranking-root|oeuvre-root|contact-page-root)"' "$file"; then
    return 0
  fi

  tmp=$(mktemp "${TMPDIR:-/tmp}/wizardry-dynamic-page.XXXXXX")
  awk '
    BEGIN {
      in_header = 0
      removed = 0
      header = ""
    }
    function flush_header() {
      if (header != "") {
        printf "%s", header
        header = ""
      }
    }
    {
      if (removed == 0 && in_header == 0 && $0 ~ /^<header([[:space:]][^>]*)?>[[:space:]]*$/) {
        in_header = 1
        header = $0 "\n"
        next
      }
      if (in_header == 1) {
        header = header $0 "\n"
        if ($0 ~ /^<\/header>[[:space:]]*$/) {
          if (header ~ /class="title"/) {
            removed = 1
            header = ""
          } else {
            flush_header()
          }
          in_header = 0
        }
        next
      }
      print
    }
    END {
      flush_header()
    }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
}

append_local_static_cache_bust() {
  html_file=$1
  cache_token=${2-}
  [ -f "$html_file" ] || return 0
  [ -n "$cache_token" ] || return 0

  tmp_html=$(temp-file html-cache-busted)
  sed -E \
    -e "s#(href|src)=\"(/static/[^\"]+\\.(css|js))(\\?v=[^\"]*)?\"#\1=\"\2?v=$cache_token\"#g" \
    -e "s#(href|src)='(/static/[^']+\\.(css|js))(\\?v=[^']*)?'#\1='\2?v=$cache_token'#g" \
    "$html_file" > "$tmp_html"
  if cmp -s "$html_file" "$tmp_html"; then
    rm -f "$tmp_html"
    return 0
  fi
  mv "$tmp_html" "$html_file"
}

compute_static_asset_cache_token() {
  static_root=$1
  if [ ! -d "$static_root" ]; then
    printf '0\n'
    return 0
  fi
  find "$static_root" -type f \
    \( -name '*.css' -o -name '*.js' \) \
    ! -name '._*' | sort | while IFS= read -r asset_file; do
    cksum "$asset_file"
  done | cksum | awk '{print $1}'
}

prune_stale_build_pages() {
  build_pages_dir=$1
  site_pages_dir=$2

  [ -d "$build_pages_dir" ] || return 0

  find "$build_pages_dir" -type f -name '*.html' ! -name '._*' | while IFS= read -r html_file; do
    rel_html=${html_file#"$build_pages_dir/"}
    rel_md=${rel_html%.html}.md
    md_file="$site_pages_dir/$rel_md"
    if [ ! -f "$md_file" ]; then
      info "  Removing stale build page: $rel_html"
      rm -f "$html_file"
    fi
  done

  find "$build_pages_dir" -depth -type d -empty -delete 2>/dev/null || true
}

normalize_tags() {
  printf '%s' "${1-}" | tr '\n' ',' | tr ',' '\n' | sed 's/^ *//;s/ *$//' | awk 'NF { if (!seen[$0]++) { if (out != "") out = out ", "; out = out $0 } } END { printf "%s", out }'
}

xml_escape() {
  printf '%s' "${1-}" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

cdata_safe() {
  printf '%s' "${1-}" | sed 's/]]>/]]]]><![CDATA[>/g'
}

valid_domain() {
  domain_value=$1
  case "$domain_value" in
    ''|.|..|.*|*.|*..*|*[!A-Za-z0-9._-]*)
      return 1
      ;;
  esac
}

iso_to_rfc822() {
  iso=${1-}
  if [ -z "$iso" ]; then
    date -u '+%a, %d %b %Y %H:%M:%S +0000'
    return 0
  fi

  if date -u -d "$iso" '+%a, %d %b %Y %H:%M:%S +0000' >/dev/null 2>&1; then
    date -u -d "$iso" '+%a, %d %b %Y %H:%M:%S +0000'
    return 0
  fi

  if date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$iso" '+%a, %d %b %Y %H:%M:%S +0000' >/dev/null 2>&1; then
    date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$iso" '+%a, %d %b %Y %H:%M:%S +0000'
    return 0
  fi

  printf '%s\n' "$iso"
}

site_base_url() {
  domain=$(config-get "$site_dir/site.conf" domain 2>/dev/null || printf 'localhost')
  use_https=$(config-get "$site_dir/site.conf" https 2>/dev/null || printf 'false')
  if ! valid_domain "$domain"; then
    die 2 "build: invalid domain"
  fi
  case "$use_https" in
    true|false) ;;
    *) die 2 "build: invalid https setting" ;;
  esac
  scheme=http
  if [ "$use_https" = "true" ]; then
    scheme=https
  fi
  printf '%s://%s\n' "$scheme" "$domain"
}

run_site_pre_build_hook() {
  hook_path=''
  for candidate in "$site_dir/cgi/pre-build" "$site_dir/pre-build"; do
    if [ -x "$candidate" ]; then
      hook_path=$candidate
      break
    fi
  done
  [ -n "$hook_path" ] || return 0

  info "Running site pre-build hook..."
  WIZARDRY_SITES_DIR="$sites_dir" \
    WIZARDRY_SITE_NAME="$site_name" \
    WIZARDRY_DIR="$WIZARDRY_DIR" \
    WEB_WIZARDRY_ROOT="$web_root" \
    "$hook_path" || die "build: site pre-build hook failed"
}

generate_blog_feeds_and_sitemap() {
  posts_dir="$site_dir/site/pages/posts"
  build_pages_dir="$site_dir/build/pages"

  if [ ! -d "$posts_dir" ]; then
    return 0
  fi

  site_title=$(config-get "$site_dir/site.conf" site_title 2>/dev/null || printf 'My Blog')
  feed_full_text=$(config-get "$site_dir/site.conf" feed_full_text 2>/dev/null || printf 'true')
  feed_items=$(config-get "$site_dir/site.conf" feed_items 2>/dev/null || printf '50')
  case "$feed_full_text" in true|false) ;; *) feed_full_text=true ;; esac
  case "$feed_items" in ''|*[!0-9]*) feed_items=50 ;; esac
  if [ "$feed_items" -lt 1 ]; then
    feed_items=1
  fi

  base_url=$(site_base_url)

  posts_tmp=$(temp-file blog-feed-posts)
  ranked_tmp=$(temp-file blog-feed-ranked)

  find "$posts_dir" -type f -name '*.md' ! -name '._*' | while IFS= read -r file; do
    visibility=$(extract_front_matter_value "$file" visibility 2>/dev/null || printf '')
    if [ -z "$visibility" ]; then
      visibility=public
    fi
    if [ "$visibility" != "public" ]; then
      continue
    fi

    published_at=$(extract_front_matter_value "$file" published_at 2>/dev/null || printf '')
    if [ -z "$published_at" ]; then
      published_at='1970-01-01T00:00:00Z'
    fi

    printf '%s|%s\n' "$published_at" "$file"
  done | sort -r > "$ranked_tmp"

  awk -F'|' '{print $2}' "$ranked_tmp" > "$posts_tmp"

  latest_iso=$(awk -F'|' 'NR==1 {print $1}' "$ranked_tmp")
  if [ -z "$latest_iso" ]; then
    latest_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  fi

  rss_file="$site_dir/build/rss.xml"
  atom_file="$site_dir/build/atom.xml"
  sitemap_file="$site_dir/build/sitemap.xml"
  robots_file="$site_dir/build/robots.txt"

  {
    printf '<?xml version="1.0" encoding="UTF-8"?>\n'
    printf '<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">\n'
    printf '  <channel>\n'
    printf '    <title>%s</title>\n' "$(xml_escape "$site_title")"
    printf '    <link>%s</link>\n' "$(xml_escape "$base_url/")"
    printf '    <description>%s</description>\n' "$(xml_escape "$site_title")"
    printf '    <language>en-us</language>\n'
    printf '    <lastBuildDate>%s</lastBuildDate>\n' "$(iso_to_rfc822 "$latest_iso")"
    printf '    <atom:link href="%s/rss.xml" rel="self" type="application/rss+xml" />\n' "$(xml_escape "$base_url")"

    count=0
    while IFS= read -r post_file; do
      count=$((count + 1))
      if [ "$count" -gt "$feed_items" ]; then
        break
      fi

      title=$(extract_front_matter_value "$post_file" title 2>/dev/null || printf 'Untitled')
      summary=$(extract_front_matter_value "$post_file" summary 2>/dev/null || printf '')
      published_at=$(extract_front_matter_value "$post_file" published_at 2>/dev/null || printf '')
      rel=${post_file#"$posts_dir/"}
      rel=${rel%.md}
      link="$base_url/pages/posts/$rel.html"

      body_md=$(extract_markdown_body "$post_file")
      if [ "$feed_full_text" = "true" ]; then
        body_html=$(
          printf '%s\n' "$body_md" |
            pandoc --from markdown+raw_html --to html5 2>/dev/null || \
            printf '<pre>%s</pre>' "$(xml_escape "$body_md")"
        )
      else
        body_html=$(xml_escape "$summary")
      fi

      printf '    <item>\n'
      printf '      <title>%s</title>\n' "$(xml_escape "$title")"
      printf '      <link>%s</link>\n' "$(xml_escape "$link")"
      printf '      <guid isPermaLink="true">%s</guid>\n' "$(xml_escape "$link")"
      if [ -n "$published_at" ]; then
        printf '      <pubDate>%s</pubDate>\n' "$(iso_to_rfc822 "$published_at")"
      fi
      printf '      <description><![CDATA[%s]]></description>\n' "$(cdata_safe "$body_html")"
      if [ "$feed_full_text" = "true" ]; then
        printf '      <content:encoded><![CDATA[%s]]></content:encoded>\n' "$(cdata_safe "$body_html")"
      fi
      printf '    </item>\n'
    done < "$posts_tmp"

    printf '  </channel>\n'
    printf '</rss>\n'
  } > "$rss_file"

  {
    printf '<?xml version="1.0" encoding="utf-8"?>\n'
    printf '<feed xmlns="http://www.w3.org/2005/Atom">\n'
    printf '  <title>%s</title>\n' "$(xml_escape "$site_title")"
    printf '  <link href="%s/atom.xml" rel="self" />\n' "$(xml_escape "$base_url")"
    printf '  <link href="%s/" />\n' "$(xml_escape "$base_url")"
    printf '  <id>%s/</id>\n' "$(xml_escape "$base_url")"
    printf '  <updated>%s</updated>\n' "$(xml_escape "$latest_iso")"

    count=0
    while IFS= read -r post_file; do
      count=$((count + 1))
      if [ "$count" -gt "$feed_items" ]; then
        break
      fi

      title=$(extract_front_matter_value "$post_file" title 2>/dev/null || printf 'Untitled')
      summary=$(extract_front_matter_value "$post_file" summary 2>/dev/null || printf '')
      published_at=$(extract_front_matter_value "$post_file" published_at 2>/dev/null || printf '')
      rel=${post_file#"$posts_dir/"}
      rel=${rel%.md}
      link="$base_url/pages/posts/$rel.html"
      if [ -z "$published_at" ]; then
        published_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      fi

      body_md=$(extract_markdown_body "$post_file")
      if [ "$feed_full_text" = "true" ]; then
        body_html=$(
          printf '%s\n' "$body_md" |
            pandoc --from markdown+raw_html --to html5 2>/dev/null || \
            printf '<pre>%s</pre>' "$(xml_escape "$body_md")"
        )
      else
        body_html=$(xml_escape "$summary")
      fi

      printf '  <entry>\n'
      printf '    <title>%s</title>\n' "$(xml_escape "$title")"
      printf '    <link href="%s" />\n' "$(xml_escape "$link")"
      printf '    <id>%s</id>\n' "$(xml_escape "$link")"
      printf '    <updated>%s</updated>\n' "$(xml_escape "$published_at")"
      printf '    <summary>%s</summary>\n' "$(xml_escape "$summary")"
      printf '    <content type="html"><![CDATA[%s]]></content>\n' "$(cdata_safe "$body_html")"
      printf '  </entry>\n'
    done < "$posts_tmp"

    printf '</feed>\n'
  } > "$atom_file"

  {
    printf '<?xml version="1.0" encoding="UTF-8"?>\n'
    printf '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n'
    printf '  <url><loc>%s</loc></url>\n' "$(xml_escape "$base_url/")"

    find "$build_pages_dir" -type f -name '*.html' | sort | while IFS= read -r html_file; do
      rel=${html_file#"$build_pages_dir/"}
      printf '  <url><loc>%s</loc></url>\n' "$(xml_escape "$base_url/pages/$rel")"
    done

    printf '  <url><loc>%s</loc></url>\n' "$(xml_escape "$base_url/rss.xml")"
    printf '  <url><loc>%s</loc></url>\n' "$(xml_escape "$base_url/atom.xml")"
    printf '</urlset>\n'
  } > "$sitemap_file"

  {
    printf 'User-agent: *\n'
    printf 'Allow: /\n\n'
    printf 'Sitemap: %s/sitemap.xml\n' "$base_url"
  } > "$robots_file"

  rm -f "$posts_tmp" "$ranked_tmp"
}

render_cgi_fragment() {
  script_path=$1
  query_string=${2-}
  out_file=$3

  if [ ! -x "$script_path" ]; then
    return 1
  fi

  raw_tmp=$(temp-file cgi-raw)
  body_tmp=$(temp-file cgi-body)

  (
    env \
      "REQUEST_METHOD=GET" \
      "CONTENT_LENGTH=0" \
      "QUERY_STRING=$query_string" \
      "WIZARDRY_DIR=$WIZARDRY_DIR" \
      "WIZARDRY_SITES_DIR=$sites_dir" \
      "WIZARDRY_SITE_NAME=$site_name" \
      "$script_path"
  ) > "$raw_tmp" 2>/dev/null || {
    rm -f "$raw_tmp" "$body_tmp"
    return 1
  }

  awk '
    BEGIN { in_body = 0 }
    {
      line = $0
      sub(/\r$/, "", line)
      if (in_body == 1) {
        print line
      } else if (line == "") {
        in_body = 1
      }
    }
  ' "$raw_tmp" > "$body_tmp"

  if [ ! -s "$body_tmp" ]; then
    cp "$raw_tmp" "$body_tmp"
  fi

  cp "$body_tmp" "$out_file"
  rm -f "$raw_tmp" "$body_tmp"
  return 0
}

build_path_newer_than() {
  candidate_path=${1-}
  target_path=${2-}
  [ -n "$candidate_path" ] || return 1
  [ -n "$target_path" ] || return 1
  [ -e "$candidate_path" ] || return 1
  [ -e "$target_path" ] || return 0
  if [ -d "$candidate_path" ]; then
    find "$candidate_path" -type f -newer "$target_path" -print -quit 2>/dev/null | grep -q .
    return $?
  fi
  [ "$candidate_path" -nt "$target_path" ]
}

blog_dynamic_section_needs_refresh() {
  target_html=${1-}
  shift || true
  [ -n "$target_html" ] || return 0
  [ -f "$target_html" ] || return 0
  [ "${full_rebuild:-0}" -eq 1 ] && return 0
  for source_path in "$@"; do
    if build_path_newer_than "$source_path" "$target_html"; then
      return 0
    fi
  done
  return 1
}

replace_html_container_by_id() {
  html_file=$1
  container_id=$2
  replacement_file=$3

  tmp_html=$(temp-file html-replaced)
  if awk -v id="$container_id" -v replacement_file="$replacement_file" '
    BEGIN {
      inside = 0
      depth = 0
      replaced = 0
    }
    {
      if (inside == 0 && index($0, "id=\"" id "\"") > 0 && $0 ~ /<div[[:space:]>]/) {
        while ((getline line < replacement_file) > 0) {
          print line
        }
        close(replacement_file)
        replaced = 1
        inside = 1
        open_count = gsub(/<div([[:space:]>])/, "&", $0)
        close_count = gsub(/<\/div>/, "&", $0)
        depth = open_count - close_count
        if (depth <= 0) {
          inside = 0
          depth = 0
        }
        next
      }

      if (inside == 1) {
        open_count = gsub(/<div([[:space:]>])/, "&", $0)
        close_count = gsub(/<\/div>/, "&", $0)
        depth = depth + open_count - close_count
        if (depth <= 0) {
          inside = 0
          depth = 0
        }
        next
      }

      print
    }
    END {
      if (replaced == 0) {
        exit 2
      }
    }
  ' "$html_file" > "$tmp_html"; then
    mv "$tmp_html" "$html_file"
    return 0
  fi

  rm -f "$tmp_html"
  return 1
}

prerender_blog_dynamic_sections() {
  if [ "$site_template" != "blog" ]; then
    return 0
  fi

  cgi_dir="$site_dir/cgi"
  if [ ! -d "$cgi_dir" ]; then
    return 0
  fi

  if [ -f "$site_dir/build/pages/index.html" ] &&
     [ -x "$cgi_dir/blog-index" ] &&
     blog_dynamic_section_needs_refresh \
       "$site_dir/build/pages/index.html" \
       "$cgi_dir/blog-index" \
       "$cgi_dir/blog-lib.sh" \
       "$cgi_dir/blog-list-common.sh" \
       "$cgi_dir/blog-nostr-pages-common.sh" \
       "$site_dir/site/pages/posts"; then
    post_list_tmp=$(temp-file blog-index-fragment)
    if render_cgi_fragment "$cgi_dir/blog-index" "page=1" "$post_list_tmp"; then
      replace_html_container_by_id "$site_dir/build/pages/index.html" "post-list" "$post_list_tmp" || true
    fi
    rm -f "$post_list_tmp"
  fi

  if [ -f "$site_dir/build/pages/tags.html" ] &&
     [ -x "$cgi_dir/blog-tags" ] &&
     blog_dynamic_section_needs_refresh \
       "$site_dir/build/pages/tags.html" \
       "$cgi_dir/blog-tags" \
       "$cgi_dir/blog-lib.sh" \
       "$cgi_dir/blog-list-common.sh" \
       "$cgi_dir/blog-nostr-pages-common.sh" \
       "$site_dir/site/pages/posts"; then
    tag_cloud_tmp=$(temp-file blog-tags-fragment)
    if render_cgi_fragment "$cgi_dir/blog-tags" "" "$tag_cloud_tmp"; then
      replace_html_container_by_id "$site_dir/build/pages/tags.html" "tag-cloud" "$tag_cloud_tmp" || true
    fi
    rm -f "$tag_cloud_tmp"
  fi

  if [ -f "$site_dir/build/pages/archive.html" ] &&
     [ -x "$cgi_dir/blog-archive" ] &&
     blog_dynamic_section_needs_refresh \
       "$site_dir/build/pages/archive.html" \
       "$cgi_dir/blog-archive" \
       "$cgi_dir/blog-lib.sh" \
       "$cgi_dir/blog-list-common.sh" \
       "$cgi_dir/blog-nostr-pages-common.sh" \
       "$site_dir/site/pages/posts"; then
    archive_list_tmp=$(temp-file blog-archive-fragment)
    if render_cgi_fragment "$cgi_dir/blog-archive" "" "$archive_list_tmp"; then
      replace_html_container_by_id "$site_dir/build/pages/archive.html" "archive-list" "$archive_list_tmp" || true
    fi
    rm -f "$archive_list_tmp"
  fi
}

build_site() {
  step "Building site: $site_name"
  shared_theme_root="$WIZARDRY_DIR/web"
  shared_theme_dir="$shared_theme_root/.themes"
  site_template=$(config-get "$site_dir/site.conf" template 2>/dev/null || printf '')

  if [ "$site_template" = "blog" ]; then
    if ! has nostril; then
      if has install-nostril; then
        info "Blog template requires nostril; attempting install..."
        install-nostril >/dev/null 2>&1 || true
      fi
    fi
    if ! has nostril; then
      if [ "${WIZARDRY_TEST_HELPERS_ONLY:-0}" = "1" ]; then
        warn "build: missing nostril in test mode; continuing"
      else
        die "build: blog template requires nostril. Run: web-wizardry install-nostril"
      fi
    fi
  fi

  if [ "$site_template" = "blog" ] && [ -x "$site_dir/cgi/blog-nostr-rebuild" ]; then
    if ! WIZARDRY_SITES_DIR="$sites_dir" WIZARDRY_SITE_NAME="$site_name" \
      "$site_dir/cgi/blog-nostr-rebuild" >/dev/null 2>&1; then
      warn "build: blog Nostr derived rebuild failed; continuing with existing local files"
    fi
  fi

  run_site_pre_build_hook

  mkdir -p "$site_dir/build/pages"
  mkdir -p "$site_dir/build/static"
  mkdir -p "$site_dir/build/static/js"

  default_js_lib_dir="$site_data_dir/.web-libs/js"
  js_lib_dir="${WIZARDRY_WEB_JS_DIR:-$default_js_lib_dir}"
  if ! mkdir -p "$js_lib_dir" 2>/dev/null; then
    warn "build: cannot write web lib cache at $js_lib_dir"
    if [ "$js_lib_dir" != "$default_js_lib_dir" ] && \
      mkdir -p "$default_js_lib_dir" 2>/dev/null; then
      info "build: using fallback cache: $default_js_lib_dir"
      js_lib_dir="$default_js_lib_dir"
    else
      die "build: failed to create web lib cache at $default_js_lib_dir"
    fi
  fi

  if [ ! -f "$js_lib_dir/htmx.min.js" ] || [ ! -f "$js_lib_dir/idiomorph-ext.min.js" ]; then
    info "Web libraries not found, installing..."
    WIZARDRY_WEB_JS_DIR="$js_lib_dir"
    export WIZARDRY_WEB_JS_DIR
    install-htmx || die "build: failed to install web libraries"
  fi

  info "Copying web libraries to build/static/js/..."
  cp "$js_lib_dir/htmx.min.js" "$site_dir/build/static/js/" || die "build: failed to copy htmx.min.js"
  cp "$js_lib_dir/idiomorph-ext.min.js" "$site_dir/build/static/js/" || die "build: failed to copy idiomorph-ext.min.js"

  if [ -d "$shared_theme_dir" ]; then
    mkdir -p "$site_dir/site/static/themes"
    cp -f "$shared_theme_dir"/*.css "$site_dir/site/static/themes/" 2>/dev/null || true
  fi

  if [ -d "$site_dir/site/static" ]; then
    info "Copying static files to build/static/..."
    cp -r "$site_dir/site/static"/* "$site_dir/build/static/" 2>/dev/null || true
  fi
  build_cache_token=$(compute_static_asset_cache_token "$site_dir/build/static")
  if [ -z "$build_cache_token" ]; then
    build_cache_token=0
  fi

  prune_stale_build_pages "$site_dir/build/pages" "$site_dir/site/pages"

  info "Converting Markdown to HTML..."
  built_count=0
  if [ -d "$site_dir/site/pages" ]; then
    md_file_count=$(
      find "$site_dir/site/pages" -type f -name '*.md' ! -name '._*' 2>/dev/null | wc -l
    )
    if [ "$md_file_count" -eq 0 ]; then
      warn "No Markdown files found in $site_dir/site/pages/"
      warn "Create .md files there to build HTML pages."
    fi

    find "$site_dir/site/pages" -type f -name '*.md' ! -name '._*' | sort | \
      while IFS= read -r md_file; do
      rel_path=${md_file#"$site_dir/site/pages/"}
      rel_html=${rel_path%.md}.html
      html_file="$site_dir/build/pages/$rel_html"
      html_dir=$(dirname "$html_file")
      mkdir -p "$html_dir"

      if [ "$full_rebuild" -eq 0 ] && [ -f "$html_file" ] && newer "$html_file" "$md_file"; then
        debug "Skipping $rel_path (up to date)"
        continue
      fi

      info "  Building: $rel_path -> $rel_html"

      htmx_header=$(temp-file htmx-header)
      cat > "$htmx_header" <<'HTMX_HEADER'
<script src="/static/js/htmx.min.js"></script>
<script src="/static/js/idiomorph-ext.min.js"></script>
HTMX_HEADER

      includes_dir="$site_dir/site/includes"
      nav_file="$includes_dir/nav.md"
      footer_file="$includes_dir/footer.md"
      nav_exists=0
      footer_exists=0
      footer_tmp=""
      if [ -f "$nav_file" ]; then
        nav_exists=1
      fi
      if [ -f "$footer_file" ]; then
        footer_exists=1
      elif [ "$site_template" = "blog" ]; then
        # Backward-compatible default footer for older blog sites that
        # predate includes/footer.md.
        footer_tmp=$(temp-file blog-default-footer)
        cat > "$footer_tmp" <<'BLOG_FOOTER'
<footer class="site-footer">
  <div class="footer-feeds" aria-label="Syndication feeds">
    <a href="/rss.xml" class="footer-feed-link" aria-label="RSS feed" title="RSS feed">
      <span>RSS</span>
    </a>
    <a href="/atom.xml" class="footer-feed-link" aria-label="Atom feed" title="Atom feed">
      <span>Atom</span>
    </a>
  </div>
</footer>
BLOG_FOOTER
        footer_file="$footer_tmp"
        footer_exists=1
      fi
      head_file="$includes_dir/head.html"
      head_arg=""
      if [ -f "$head_file" ]; then
        head_arg="--include-in-header=$head_file"
      fi

      pandoc \
        --from markdown+yaml_metadata_block+raw_html \
        --to html5 \
        --standalone \
        --css=/static/style.css \
        --include-in-header="$htmx_header" \
        $head_arg \
        --output="$html_file" \
        "$md_file"

      if [ "$nav_exists" -eq 1 ]; then
        temp_html=$(temp-file html-with-nav)
        awk -v nav_file="$nav_file" '
          /<body>/ {
            print
            while ((getline line < nav_file) > 0) {
              print line
            }
            close(nav_file)
            next
          }
          { print }
        ' "$html_file" > "$temp_html"
        mv "$temp_html" "$html_file"
      fi

      if [ "$footer_exists" -eq 1 ]; then
        temp_html=$(temp-file html-with-footer)
        awk -v footer_file="$footer_file" '
          /<\/body>/ {
            while ((getline line < footer_file) > 0) {
              print line
            }
            close(footer_file)
            print
            next
          }
          { print }
        ' "$html_file" > "$temp_html"
        mv "$temp_html" "$html_file"
      fi

      strip_dynamic_title_block "$html_file"

      rm -f "$htmx_header"
      if [ -n "$footer_tmp" ] && [ -f "$footer_tmp" ]; then
        rm -f "$footer_tmp"
      fi
      chmod 644 "$html_file"
      built_count=$((built_count + 1))
      printf '%s\n' "$built_count" > "$site_dir/build/.build-count.tmp"
    done

    if [ -f "$site_dir/build/.build-count.tmp" ]; then
      built_count=$(cat "$site_dir/build/.build-count.tmp" 2>/dev/null || printf '0')
      rm -f "$site_dir/build/.build-count.tmp"
    fi
  else
    warn "Pages directory not found: $site_dir/site/pages/"
    warn "Expected site structure:"
    warn "  $site_dir/site/pages/    - Markdown files (.md)"
    warn "  $site_dir/site/static/   - CSS, images, etc."
    warn "  $site_dir/build/         - Generated HTML (output)"
  fi

  generate_blog_feeds_and_sitemap
  prerender_blog_dynamic_sections

  find "$site_dir/build/pages" -type f -name '*.html' ! -name '._*' | \
    while IFS= read -r html_page; do
    append_local_static_cache_bust "$html_page" "$build_cache_token"
  done
  find "$site_dir/build/pages" -type f -name '*.html' ! -name '._*' -exec chmod 644 {} +

  date -u +%Y-%m-%dT%H:%M:%SZ > "$site_dir/build/.wizardry-build-stamp"
  chmod 644 "$site_dir/build/.wizardry-build-stamp" 2>/dev/null || true

  success "Built $built_count pages for $site_name"
  info "Build output: $site_dir/build/"
}

if [ "$watch_mode" -eq 1 ]; then
  step "Watching $site_name for changes (Ctrl-C to stop)"
  while true; do
    build_site
    sleep 2
  done
else
  build_site
fi
