#!/bin/sh

# Show status of a wizardry web site.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: site-status SITENAME

Shows the status of a website including build state and serving status.

Example: web-site-status mysite
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

site_name=${1-}
if [ -z "$site_name" ]; then
  die 2 "site-status: SITENAME required"
fi
case "$site_name" in
  .|..|*[!a-zA-Z0-9._-]*)
    die 2 "site-status: invalid site name"
    ;;
esac

web_root=${WEB_WIZARDRY_ROOT:-$HOME/sites}
sites_dir="$web_root"
site_dir="$sites_dir/$site_name"

if [ ! -d "$site_dir" ]; then
  printf 'not found\n'
  exit 1
fi

# Check if built
if [ -d "$site_dir/build" ] && [ -f "$site_dir/build/pages/index.html" ]; then
  build_status="built"
else
  build_status="not built"
fi

# Check if serving
serve_status="not serving"

site_status_nginx_pid_running() {
  pid=$1
  case "$pid" in
    ''|*[!0-9]*)
      return 1
      ;;
  esac

  if ! kill -0 "$pid" 2>/dev/null; then
    return 1
  fi

  if ! has ps; then
    return 0
  fi

  cmd=$(ps -p "$pid" -o command= 2>/dev/null || printf '')
  case "$cmd" in
    *nginx*"$site_dir"*|*nginx*)
      return 0
      ;;
  esac
  return 1
}

if [ -f "$site_dir/nginx/nginx.pid" ]; then
  pid=$(cat "$site_dir/nginx/nginx.pid" 2>/dev/null || echo "")
  if site_status_nginx_pid_running "$pid"; then
    serve_status="serving"
  fi
fi

if [ "$serve_status" = "not serving" ]; then
  if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && has launchctl; then
    label="org.wizardry.web.${site_name}"
    if launchctl print "system/$label" 2>/dev/null | grep -q "state = running"; then
      serve_status="serving"
    fi
  elif has systemctl; then
    unit="wizardry-site-${site_name}.service"
    if systemctl is-active --quiet "$unit" 2>/dev/null; then
      serve_status="serving"
    fi
  fi
fi

printf '%s, %s\n' "$build_status" "$serve_status"
