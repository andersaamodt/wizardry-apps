#!/bin/sh
# Remove filesystem growth tools from the host.
# Cleans package-manager and source-based installations.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-filesystem-tools

Removes filesystem growth tools when they were installed through a supported
package manager.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

fs_tools_path_prefix="/opt/homebrew/opt/e2fsprogs/sbin:/opt/homebrew/opt/e2fsprogs/bin:"\
"/usr/local/opt/e2fsprogs/sbin:/usr/local/opt/e2fsprogs/bin:"\
"/opt/homebrew/opt/xfsprogs/bin:/usr/local/opt/xfsprogs/bin"
PATH="$fs_tools_path_prefix:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

uninstall_fs_say() {
  printf '%s\n' "$1"
}

uninstall_fs_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

uninstall_fs_run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if command -v run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if uninstall_fs_has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

all_absent() {
  ! uninstall_fs_has_cmd resize2fs && ! uninstall_fs_has_cmd xfs_growfs
}

if all_absent; then
  uninstall_fs_say "Filesystem tools are already absent"
  exit 0
fi

removed=0

if uninstall_fs_has_cmd apt-get; then
  uninstall_fs_run_privileged env DEBIAN_FRONTEND=noninteractive \
    apt-get remove -y e2fsprogs xfsprogs >/dev/null 2>&1 || true
  removed=1
elif uninstall_fs_has_cmd dnf; then
  uninstall_fs_run_privileged dnf remove -y e2fsprogs xfsprogs >/dev/null 2>&1 || true
  removed=1
elif uninstall_fs_has_cmd brew; then
  brew uninstall e2fsprogs xfsprogs >/dev/null 2>&1 || true
  removed=1
fi

if all_absent; then
  uninstall_fs_say "Uninstalled filesystem tools"
  exit 0
fi

if [ "$removed" -eq 0 ]; then
  uninstall_fs_say "uninstall-filesystem-tools: no supported package manager found." >&2
else
  uninstall_fs_say "uninstall-filesystem-tools: filesystem tools are still present on PATH" >&2
fi
exit 1
