#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-filesystem-tools

Removes filesystem growth tools when they were installed through a supported
package manager.
USAGE
  exit 0
  ;;
esac

set -eu

PATH=/opt/homebrew/opt/e2fsprogs/sbin:/opt/homebrew/opt/e2fsprogs/bin:/usr/local/opt/e2fsprogs/sbin:/usr/local/opt/e2fsprogs/bin:/opt/homebrew/opt/xfsprogs/bin:/usr/local/opt/xfsprogs/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

say() {
  printf '%s\n' "$1"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if type run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

all_absent() {
  ! has_cmd resize2fs && ! has_cmd xfs_growfs
}

if all_absent; then
  say "Filesystem tools are already absent"
  exit 0
fi

removed=0

if has_cmd apt-get; then
  run_privileged env DEBIAN_FRONTEND=noninteractive apt-get remove -y e2fsprogs xfsprogs >/dev/null 2>&1 || true
  removed=1
elif has_cmd dnf; then
  run_privileged dnf remove -y e2fsprogs xfsprogs >/dev/null 2>&1 || true
  removed=1
elif has_cmd brew; then
  brew uninstall e2fsprogs xfsprogs >/dev/null 2>&1 || true
  removed=1
fi

if all_absent; then
  say "Uninstalled filesystem tools"
  exit 0
fi

if [ "$removed" -eq 0 ]; then
  say "uninstall-filesystem-tools: no supported package manager found." >&2
else
  say "uninstall-filesystem-tools: filesystem tools are still present on PATH" >&2
fi
exit 1
