#!/bin/sh
# Remove jq when it was installed by Wizardry-supported methods.
# Cleans package-manager and known local binary installs.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-jq

Removes jq when it was installed through a supported package manager or a
known local binary path.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

jq_uninstall_say() {
  printf '%s\n' "$1"
}

jq_uninstall_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

jq_uninstall_run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if command -v run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if jq_uninstall_has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

remove_known_jq_binary() {
  removed=1
  for candidate in \
    "$(command -v jq 2>/dev/null || printf '')" \
    "${XDG_BIN_HOME:-$HOME/.local/bin}/jq" \
    "/usr/local/bin/jq" \
    "/opt/homebrew/bin/jq"
  do
    [ -n "$candidate" ] || continue
    [ -f "$candidate" ] || continue
    jq_uninstall_run_privileged rm -f "$candidate"
  done
}

removed=0

if jq_uninstall_has_cmd apt-get; then
  jq_uninstall_run_privileged env DEBIAN_FRONTEND=noninteractive \
    apt-get remove -y jq >/dev/null 2>&1 || true
  removed=1
elif jq_uninstall_has_cmd dnf; then
  jq_uninstall_run_privileged dnf remove -y jq >/dev/null 2>&1 || true
  removed=1
elif jq_uninstall_has_cmd brew; then
  brew uninstall jq >/dev/null 2>&1 || true
  removed=1
fi

remove_known_jq_binary || true

if jq_uninstall_has_cmd jq; then
  jq_uninstall_say "uninstall-jq: jq is still present on PATH" >&2
  exit 1
fi

if [ "$removed" -eq 0 ]; then
  jq_uninstall_say "jq is not installed"
  exit 0
fi

jq_uninstall_say "Uninstalled jq"
