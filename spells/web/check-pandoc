#!/bin/sh
# Check whether pandoc is installed and callable.
# Used by static site build and content conversion flows.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: check-pandoc

Checks whether pandoc is available for Wizardry site builds.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

if command -v pandoc >/dev/null 2>&1; then
  printf 'status=ok\n'
  printf 'summary=%s\n' 'pandoc is available on PATH.'
  exit 0
fi

printf 'status=bad\n'
printf 'summary=%s\n' 'pandoc is not installed.'
exit 0
