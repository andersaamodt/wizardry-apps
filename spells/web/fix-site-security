#!/bin/sh

# Ensure per-site user exists and fix directory permissions.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: fix-site-security SITENAME

Ensures a per-site user exists and tightens permissions for:
  - site directory
  - .sitedata directory
  - allowlisted directories from site.allowlist

Example: web-fix-site-security mysite
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

site_name=${1-}
if [ -z "$site_name" ]; then
  die 2 "fix-site-security: SITENAME required"
fi

case "$site_name" in
  .|..|*[!a-zA-Z0-9._-]*)
    die 2 "fix-site-security: invalid site name"
    ;;
esac

web_root=${WEB_WIZARDRY_ROOT:-$HOME/sites}
sites_dir="$web_root"
site_dir="$sites_dir/$site_name"
site_data_dir="$sites_dir/.sitedata/$site_name"
site_config="$site_dir/site.conf"
allowlist_file="$site_dir/site.allowlist"

if [ ! -d "$site_dir" ]; then
  die "fix-site-security: site '$site_name' not found"
fi

fix_security_run_priv() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return
  fi

  if has sudo; then
    sudo "$@"
    return
  fi

  die "fix-site-security: root or sudo is required"
}

site_user_default="ww_$(printf '%s' "$site_name" | tr 'A-Z' 'a-z' | tr '.-' '__')"
site_user=$(config-get "$site_config" site-user 2>/dev/null || printf '')
if [ -z "$site_user" ]; then
  site_user="$site_user_default"
  if [ -w "$site_config" ]; then
    config-set "$site_config" site-user "$site_user"
  elif [ "$(id -u)" -eq 0 ] || has sudo; then
    fix_security_run_priv config-set "$site_config" site-user "$site_user"
  else
    warn "fix-site-security: cannot update site.conf without root or sudo"
  fi
fi
case "$site_user" in
  ''|.|..|-*|*[!a-zA-Z0-9._-]*)
    die 2 "fix-site-security: invalid site-user in site.conf"
    ;;
esac
site_group="$site_user"

group_exists() {
  if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && has dscl; then
    dscl . -read "/Groups/$1" >/dev/null 2>&1
    return $?
  fi
  if has getent; then
    getent group "$1" >/dev/null 2>&1
    return $?
  fi
  grep -q "^$1:" /etc/group 2>/dev/null
}

ensure_site_group() {
  if group_exists "$site_group"; then
    return 0
  fi

  if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && has dscl; then
    max_gid=$(dscl . -list /Groups PrimaryGroupID 2>/dev/null | \
      awk '{print $2}' | sort -n | tail -1)
    case "$max_gid" in
      ''|*[!0-9]*) max_gid=500 ;;
    esac
    gid=$((max_gid + 1))

    fix_security_run_priv dscl . -create "/Groups/$site_group"
    fix_security_run_priv dscl . -create "/Groups/$site_group" PrimaryGroupID "$gid"
    fix_security_run_priv dscl . -create "/Groups/$site_group" RealName "Wizardry Site $site_name"
    fix_security_run_priv dscl . -create "/Groups/$site_group" GroupMembership "$site_user"
    fix_security_run_priv dscl . -create "/Users/$site_user" PrimaryGroupID "$gid"
    return 0
  fi

  if has groupadd; then
    fix_security_run_priv groupadd "$site_group"
    return 0
  fi

  if has addgroup; then
    if addgroup --help 2>&1 | grep -q -- '--system'; then
      fix_security_run_priv addgroup --system "$site_group"
    else
      fix_security_run_priv addgroup "$site_group"
    fi
    return 0
  fi

  if has pw; then
    fix_security_run_priv pw groupadd "$site_group"
    return 0
  fi

  die "fix-site-security: unable to create group '$site_group'"
}

ensure_staff_membership() {
  if [ "$(uname -s 2>/dev/null)" != "Darwin" ] || ! has dscl; then
    return 0
  fi
  fix_security_run_priv dscl . -append /Groups/staff GroupMembership "$site_user" \
    >/dev/null 2>&1 || true
}

assign_site_user_primary_group() {
  current_group=$(id -gn "$site_user" 2>/dev/null || printf '')
  if [ -n "$current_group" ] && [ "$current_group" = "$site_group" ]; then
    return 0
  fi

  if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && has dscl; then
    return 0
  fi

  if has usermod; then
    fix_security_run_priv usermod -g "$site_group" "$site_user"
    return 0
  fi

  if has pw; then
    fix_security_run_priv pw usermod "$site_user" -g "$site_group"
    return 0
  fi

  die "fix-site-security: unable to assign primary group '$site_group' to '$site_user'"
}

ensure_site_user() {
  if id -u "$site_user" >/dev/null 2>&1; then
    return 0
  fi

  if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && has dscl; then
    max_uid=$(dscl . -list /Users UniqueID 2>/dev/null | \
      awk '{print $2}' | sort -n | tail -1)
    case "$max_uid" in
      ''|*[!0-9]*) max_uid=500 ;;
    esac
    uid=$((max_uid + 1))
    max_gid=$(dscl . -list /Groups PrimaryGroupID 2>/dev/null | \
      awk '{print $2}' | sort -n | tail -1)
    case "$max_gid" in
      ''|*[!0-9]*) max_gid=500 ;;
    esac
    gid=$((max_gid + 1))
    fix_security_run_priv dscl . -create "/Users/$site_user"
    fix_security_run_priv dscl . -create "/Users/$site_user" UserShell /usr/sbin/nologin
    fix_security_run_priv dscl . -create "/Users/$site_user" RealName "Wizardry Site $site_name"
    fix_security_run_priv dscl . -create "/Users/$site_user" UniqueID "$uid"
    fix_security_run_priv dscl . -create "/Groups/$site_user"
    fix_security_run_priv dscl . -create "/Groups/$site_user" PrimaryGroupID "$gid"
    fix_security_run_priv dscl . -create "/Groups/$site_user" RealName "Wizardry Site $site_name"
    fix_security_run_priv dscl . -create "/Groups/$site_user" GroupMembership "$site_user"
    fix_security_run_priv dscl . -create "/Users/$site_user" PrimaryGroupID "$gid"
    fix_security_run_priv dscl . -create "/Users/$site_user" NFSHomeDirectory /var/empty
    return 0
  fi

  useradd_supports() {
    flag=$1
    if useradd --help 2>&1 | grep -q -- " $flag"; then
      return 0
    fi
    useradd -h 2>&1 | grep -q -- " $flag"
  }

  if has useradd; then
    if useradd_supports -m && useradd_supports -s; then
      fix_security_run_priv useradd -m -s /usr/sbin/nologin "$site_user"
    elif useradd_supports -m; then
      fix_security_run_priv useradd -m "$site_user"
    elif useradd_supports -s; then
      fix_security_run_priv useradd -s /usr/sbin/nologin "$site_user"
    else
      fix_security_run_priv useradd "$site_user"
    fi
    return 0
  fi

  if has adduser; then
    fix_security_run_priv adduser --disabled-login --gecos "" --shell /usr/sbin/nologin "$site_user"
    return 0
  fi

  die "fix-site-security: unable to create user '$site_user' (missing useradd/adduser)"
}

set_secure_perms() {
  target=$1
  if [ ! -e "$target" ]; then
    return 0
  fi

  fix_security_run_priv find "$target" -type d -exec chmod 750 {} +
  fix_security_run_priv find "$target" -type f -exec chmod 640 {} +
}

fix_security_canonical_dir() {
  (CDPATH= cd -- "$1" 2>/dev/null && pwd -P)
}

allowlist_dir_is_safe() {
  allow_path=$1
  case "$allow_path" in
    *"$(printf '\r')"*)
      warn "fix-site-security: allowlist path contains control characters"
      return 1
      ;;
    /*) ;;
    *)
      warn "fix-site-security: allowlist path must be absolute: $allow_path"
      return 1
      ;;
  esac
  if [ ! -d "$allow_path" ]; then
    warn "fix-site-security: allowlist path must be an existing directory: $allow_path"
    return 1
  fi

  allow_real=$(fix_security_canonical_dir "$allow_path") || {
    warn "fix-site-security: allowlist path cannot be resolved: $allow_path"
    return 1
  }
  sites_real=$(fix_security_canonical_dir "$sites_dir") || sites_real=$sites_dir
  site_real=$(fix_security_canonical_dir "$site_dir") || site_real=$site_dir
  sitedata_root_real=$(fix_security_canonical_dir "$sites_dir/.sitedata" 2>/dev/null || printf '')
  home_real=
  if [ -n "${HOME-}" ]; then
    home_real=$(fix_security_canonical_dir "$HOME" 2>/dev/null || printf '')
  fi

  case "$allow_real" in
    /)
      warn "fix-site-security: allowlist path is too broad: $allow_path"
      return 1
      ;;
    "$sites_real"|"$site_real"|"$site_real"/*)
      warn "fix-site-security: allowlist path is managed by this site already: $allow_path"
      return 1
      ;;
  esac
  if [ -n "$sitedata_root_real" ]; then
    case "$allow_real" in
      "$sitedata_root_real"|"$sitedata_root_real"/*)
        warn "fix-site-security: allowlist path is managed site data: $allow_path"
        return 1
        ;;
    esac
  fi
  if [ -n "$home_real" ] && [ "$allow_real" = "$home_real" ]; then
    warn "fix-site-security: allowlist path is too broad: $allow_path"
    return 1
  fi
  return 0
}

apply_allowlist() {
  if [ ! -f "$allowlist_file" ]; then
    return 0
  fi

  while IFS= read -r line || [ -n "$line" ]; do
    line=$(printf '%s' "$line" | sed 's/#.*$//' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ -z "$line" ] && continue

    if ! allowlist_dir_is_safe "$line"; then
      continue
    fi

    fix_security_run_priv chown -R "$site_user":"$site_group" "$line"
    set_secure_perms "$line"
  done < "$allowlist_file"
}

ensure_site_user
ensure_site_group
assign_site_user_primary_group
ensure_staff_membership
if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && ! group_exists "$site_group"; then
  site_group=staff
fi

# Determine the actual user (non-site user) who should own source files
# If running via sudo, use SUDO_USER; otherwise use current user
actual_user="${SUDO_USER:-$(id -un)}"
# Don't use site user as actual user
if [ "$actual_user" = "$site_user" ]; then
  # If we can't determine actual user, check who owns site.conf
  if [ -f "$site_config" ]; then
    # Try stat (Linux and BSD/macOS have different syntax)
    if command -v stat >/dev/null 2>&1; then
      # Try GNU stat first (Linux)
      actual_user=$(stat -c '%U' "$site_config" 2>/dev/null) || \
        # Try BSD stat (macOS)
        actual_user=$(stat -f '%Su' "$site_config" 2>/dev/null) || \
        # Fallback to ls parsing if stat fails
        actual_user=$(ls -ld "$site_config" 2>/dev/null | awk '{print $3}')
    else
      # No stat available, use ls
      actual_user=$(ls -ld "$site_config" 2>/dev/null | awk '{print $3}')
    fi
  fi
fi

fix_security_run_priv mkdir -p "$sites_dir/.sitedata" "$site_data_dir"
fix_security_run_priv mkdir -p "$site_dir/build" "$site_dir/nginx"

# Set ownership based on who needs to write vs who needs to read
# - build/: actual user builds, site user (nginx) reads → actual user owns
# - nginx/: actual user and site user both write runtime files → actual user owns + group-writable
# - .sitedata/: actual user (runs nginx/fcgiwrap/CGI) writes → actual user owns
fix_security_run_priv chown -R "$actual_user":"$site_group" "$site_dir/build"
fix_security_run_priv chown -R "$actual_user":"$site_group" "$site_dir/nginx"
fix_security_run_priv chown -R "$actual_user":"$site_group" "$site_data_dir"

# Set permissions on build directory - actual user writes, site user reads
if [ -d "$site_dir/build" ]; then
  fix_security_run_priv find "$site_dir/build" -type d -exec chmod 755 {} + 2>/dev/null || true
  fix_security_run_priv find "$site_dir/build" -type f -exec chmod 644 {} + 2>/dev/null || true
fi

# Set permissions on nginx directory - both actual user and site user need write access.
# Create nginx temp directories if they don't exist (nginx writes to these)
if [ -d "$site_dir/nginx" ]; then
  fix_security_run_priv mkdir -p "$site_dir/nginx/temp/client_body"
  fix_security_run_priv mkdir -p "$site_dir/nginx/temp/proxy"
  fix_security_run_priv mkdir -p "$site_dir/nginx/temp/fastcgi"
  fix_security_run_priv mkdir -p "$site_dir/nginx/temp/uwsgi"
  fix_security_run_priv mkdir -p "$site_dir/nginx/temp/scgi"
  
  # Group-write allows the site user to create/update pid, logs, sockets, and temp files.
  fix_security_run_priv find "$site_dir/nginx" -type d -exec chmod 775 {} + 2>/dev/null || true
  fix_security_run_priv find "$site_dir/nginx" -type f -exec chmod 664 {} + 2>/dev/null || true
fi

# Set permissions on site data directory - make it accessible to actual user
# so "Open site data" works. Use 755 for dirs so user can cd into it.
# Files need 664 so site user (owner) can write to them (e.g., chat logs)
if [ -d "$site_data_dir" ]; then
  fix_security_run_priv find "$site_data_dir" -type d -exec chmod 755 {} + 2>/dev/null || true
  fix_security_run_priv find "$site_data_dir" -type f -exec chmod 664 {} + 2>/dev/null || true
fi

# Ensure site directory itself is accessible (755) and owned by actual user
if [ -d "$site_dir" ]; then
  fix_security_run_priv chown "$actual_user":"$site_group" "$site_dir"
  fix_security_run_priv chmod 755 "$site_dir"
fi

# Ensure source directories are owned by actual user and readable by site user
if [ -d "$site_dir/site" ]; then
  fix_security_run_priv chown -R "$actual_user":"$site_group" "$site_dir/site"
  fix_security_run_priv find "$site_dir/site" -type d -exec chmod 755 {} + 2>/dev/null || true
  fix_security_run_priv find "$site_dir/site" -type f -exec chmod 644 {} + 2>/dev/null || true
fi

# Fix allowlist permissions BEFORE reading it in apply_allowlist
if [ -f "$allowlist_file" ]; then
  # Keep allowlist owned by actual user but readable by site user
  fix_security_run_priv chown "$actual_user":"$site_group" "$allowlist_file"
  fix_security_run_priv chmod 644 "$allowlist_file"
fi

# Now we can safely read the allowlist file
apply_allowlist

if [ -f "$site_config" ]; then
  # Keep config owned by actual user but readable by site user
  fix_security_run_priv chown "$actual_user":"$site_group" "$site_config"
  fix_security_run_priv chmod 644 "$site_config"
fi

success "Site security fixed for '$site_name' (user: $site_user)"
