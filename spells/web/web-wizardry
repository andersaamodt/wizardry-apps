#!/bin/sh

# Wizardry web platform - create and manage UNIX-centric websites.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: web-wizardry [COMMAND]

Wizardry web platform provides a unified interface for creating and managing
UNIX-centric websites with interactivity backed by POSIX shell scripts.

Commands:
  create SITENAME    Create a new website
  create-from-template SITENAME TEMPLATE
                    Create a website from a named template and build it
  build SITENAME     Build a website
  rebuild SITENAME   Build everything and restart the site server
  serve SITENAME     Start serving a website
  stop SITENAME      Stop serving a website
  status [SITENAME]  Show website status
  configure SITENAME Configure website settings
  autorebuild SITENAME [status|enable|disable|toggle]
                    Manage automatic rebuild watcher + cron for a site
  nostr-mirror SITENAME  Mirror Nostr events for a blog site
  check-filesystem-tools Check filesystem growth tooling
  install-filesystem-tools Ensure filesystem growth tooling is installed
  uninstall-filesystem-tools Remove filesystem growth tooling
  check-nostril    Check Nostr server tooling
  install-nostril Ensure nostril is installed
  uninstall-nostril Remove nostril
  btcpay-status   Show BTCPay install status text
  check-btcpay    Check BTCPay Server tooling/runtime
  install-btcpay Ensure BTCPay Server is installed
  uninstall-btcpay Remove BTCPay Server

Without arguments, opens an interactive menu.

The web platform integrates:
  - Pandoc (Markdown to HTML)
  - nginx (web server)
  - fcgiwrap (CGI execution)
  - Let's Encrypt (HTTPS)
  - htmx (client-side interactivity)

All site files live under $HOME/sites/SITENAME/
Build output goes to $HOME/sites/SITENAME/build/
CGI scripts may live in $HOME/sites/SITENAME/cgi/ (site-specific) or spells/.imps/cgi/ (shared)
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear
. colors

if ! require menu "The web-wizardry command needs the 'menu' command."; then
  exit 1
fi

# Catch Ctrl-C and TERM signal to exit cleanly
trap 'exit 130' INT
trap 'exit 0' TERM

# Default web root directory
web_root=${WEB_WIZARDRY_ROOT:-$HOME/sites}
sites_dir="$web_root"

web_site_name_is_valid() {
  case "${1-}" in
    .|..|''|*[!a-zA-Z0-9._-]*)
      return 1
      ;;
  esac
  return 0
}

require_web_site_name() {
  command_name=$1
  site_name=${2-}
  if [ -z "$site_name" ]; then
    die 2 "web-wizardry: $command_name requires SITENAME argument"
  fi
  if ! web_site_name_is_valid "$site_name"; then
    die 2 "web-wizardry: invalid site name"
  fi
}

# Ensure web root exists
if [ ! -d "$web_root" ]; then
  mkdir -p "$web_root"
fi

# Handle command-line arguments
cmd=${1-}
case "$cmd" in
  create)
    site_name=${2-}
    require_web_site_name create "$site_name"
    create-site "$site_name"
    exit 0
    ;;
  create-from-template)
    site_name=${2-}
    template_name=${3-}
    if [ -z "$site_name" ] || [ -z "$template_name" ]; then
      die 2 "web-wizardry: create-from-template requires SITENAME and TEMPLATE"
    fi
    if ! web_site_name_is_valid "$site_name"; then
      die 2 "web-wizardry: invalid site name"
    fi
    create-from-template "$site_name" "$template_name"
    build "$site_name"
    exit 0
    ;;
  build)
    site_name=${2-}
    require_web_site_name build "$site_name"
    build "$site_name"
    exit 0
    ;;
  rebuild)
    site_name=${2-}
    require_web_site_name rebuild "$site_name"
    build "$site_name" --full
    restart-site "$site_name"
    exit 0
    ;;
  status)
    site_name=${2-}
    if [ -n "$site_name" ]; then
      if ! web_site_name_is_valid "$site_name"; then
        die 2 "web-wizardry: invalid site name"
      fi
      site-status "$site_name"
    else
      # Show all sites
      if [ -d "$sites_dir" ]; then
        for site in "$sites_dir"/*; do
          [ -d "$site" ] || continue
          name=$(basename "$site")
          web_site_name_is_valid "$name" || continue
          printf '%s: ' "$name"
          site-status "$name"
        done
      else
        printf 'No sites found\n'
      fi
    fi
    exit 0
    ;;
  serve)
    site_name=${2-}
    require_web_site_name serve "$site_name"
    serve-site "$site_name"
    exit 0
    ;;
  stop)
    site_name=${2-}
    require_web_site_name stop "$site_name"
    stop-site "$site_name"
    exit 0
    ;;
  configure)
    site_name=${2-}
    require_web_site_name configure "$site_name"
    shift 2
    configure-nginx "$site_name" "$@"
    exit 0
    ;;
  autorebuild)
    site_name=${2-}
    require_web_site_name autorebuild "$site_name"
    autorebuild_action=${3-status}
    case "$autorebuild_action" in
      status|enable|disable|toggle)
        site-autorebuild "$autorebuild_action" "$site_name"
        ;;
      *)
        die 2 "web-wizardry: autorebuild action must be status|enable|disable|toggle"
        ;;
    esac
    exit 0
    ;;
  nostr-mirror)
    site_name=${2-}
    require_web_site_name nostr-mirror "$site_name"
    blog-nostr-mirror "$site_name"
    exit 0
    ;;
  check-filesystem-tools)
    check-filesystem-tools
    exit 0
    ;;
  install-filesystem-tools)
    install-filesystem-tools
    exit 0
    ;;
  uninstall-filesystem-tools)
    uninstall-filesystem-tools
    exit 0
    ;;
  check-nostril)
    check-nostril
    exit 0
    ;;
  install-nostril)
    install-nostril
    exit 0
    ;;
  uninstall-nostril)
    uninstall-nostril
    exit 0
    ;;
  btcpay-status)
    btcpay-status
    exit 0
    ;;
  check-btcpay)
    check-btcpay
    exit 0
    ;;
  install-btcpay)
    install-btcpay
    exit 0
    ;;
  uninstall-btcpay)
    uninstall-btcpay
    exit 0
    ;;
  '')
    # No command - show interactive menu
    ;;
  *)
    die 2 "web-wizardry: unknown command '$cmd'"
    ;;
esac
# Interactive menu
while true; do
  # Menu options
  exit_label=$(exit-label)
  
  # Build menu arguments starting with existing sites
  set --
  site_count=0
  
  # Add existing sites as menu items first
  if [ -d "$sites_dir" ]; then
    for site in "$sites_dir"/*; do
      [ -d "$site" ] || continue
      name=$(basename "$site")
      set -- "$@" "${name}%site-menu \"${name}\""
      site_count=$((site_count + 1))
    done
    
    # Add separator after sites (only if sites exist)
    if [ "$site_count" -gt 0 ]; then
      set -- "$@" "---"
    fi
  fi
  
  # Add create options (template first, then blank)
  set -- "$@" "Create from template%template-menu" "Create blank site%create-site-prompt"
  
  # Add exit option
  set -- "$@" "${exit_label}%kill -TERM \$PPID"

  menu "${BOLD}${CYAN}web wizardry platform" "$@" || menu_status=$?
  menu_status=${menu_status:-0}
  
  # ESC causes menu to exit with 130 - handle gracefully by exiting
  if [ "$menu_status" -eq 130 ]; then
    printf 'ESC\n' >&2
    exit 0
  fi
done
