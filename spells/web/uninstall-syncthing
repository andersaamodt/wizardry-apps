#!/bin/sh
# Remove Syncthing when installed by supported methods.
# Cleans package-manager and downloaded binary installations.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-syncthing

Removes Syncthing when it was installed through a supported package manager.
USAGE
  exit 0
  ;;
esac

set -eu
. env-clear

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

syncthing_uninstall_say() {
  printf '%s\n' "$1"
}

syncthing_uninstall_has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

syncthing_uninstall_run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if command -v run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if syncthing_uninstall_has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

if ! syncthing_uninstall_has_cmd syncthing; then
  syncthing_uninstall_say "Syncthing is already absent"
  exit 0
fi

if syncthing_uninstall_has_cmd apt-get; then
  syncthing_uninstall_run_privileged env DEBIAN_FRONTEND=noninteractive \
    apt-get remove -y syncthing >/dev/null
elif syncthing_uninstall_has_cmd dnf; then
  syncthing_uninstall_run_privileged dnf remove -y syncthing >/dev/null
elif syncthing_uninstall_has_cmd brew; then
  brew uninstall syncthing >/dev/null
else
  syncthing_uninstall_say "uninstall-syncthing: no supported package manager found." >&2
  exit 1
fi

if syncthing_uninstall_has_cmd syncthing; then
  syncthing_uninstall_say "uninstall-syncthing: removal incomplete. Ensure syncthing is removed from PATH." >&2
  exit 1
fi

syncthing_uninstall_say "Removed Syncthing"
exit 0
