#!/bin/sh

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall-syncthing

Removes Syncthing when it was installed through a supported package manager.
USAGE
  exit 0
  ;;
esac

set -eu

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}

say() {
  printf '%s\n' "$1"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

run_privileged() {
  if "$@" 2>/dev/null; then
    return 0
  fi
  if type run_sudo_cmd >/dev/null 2>&1; then
    run_sudo_cmd "$@"
    return 0
  fi
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return 0
  fi
  if has_cmd sudo; then
    sudo "$@"
    return 0
  fi
  "$@"
}

if ! has_cmd syncthing; then
  say "Syncthing is already absent"
  exit 0
fi

if has_cmd apt-get; then
  run_privileged env DEBIAN_FRONTEND=noninteractive apt-get remove -y syncthing >/dev/null
elif has_cmd dnf; then
  run_privileged dnf remove -y syncthing >/dev/null
elif has_cmd brew; then
  brew uninstall syncthing >/dev/null
else
  say "uninstall-syncthing: no supported package manager found." >&2
  exit 1
fi

if has_cmd syncthing; then
  say "uninstall-syncthing: removal incomplete. Ensure syncthing is removed from PATH." >&2
  exit 1
fi

say "Removed Syncthing"
exit 0
