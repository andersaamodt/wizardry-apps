    fi
    case "$run_mode" in
      programming)
        if [ "$run_time_budget" -lt 420 ]; then
          run_time_budget=420
        fi
        ;;
      report)
        if [ "$run_time_budget" -lt 900 ]; then
          run_time_budget=900
        fi
        ;;
      teacher)
        if [ "$run_time_budget" -lt 900 ]; then
          run_time_budget=900
        fi
        ;;
