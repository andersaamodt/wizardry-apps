queue_pending_paths_sorted() {
  pending_dir=$1
  find "$pending_dir" -maxdepth 1 -type f -name '*__*.txt' 2>/dev/null \
    | awk -F/ '
      {
        name = $NF
        split(name, parts, "__")
        order = parts[1]
        if (order ~ /^-?[0-9]+$/) {
          print order "\t" $0
        }
      }
    ' \
    | sort -n -k1,1 \
    | cut -f2-
}

