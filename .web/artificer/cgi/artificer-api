  extras_added=0

  while IFS= read -r candidate_model; do
    candidate_model=$(trim "$candidate_model")
    [ -n "$candidate_model" ] || continue
    lower=$(printf '%s' "$candidate_model" | tr '[:upper:]' '[:lower:]')
