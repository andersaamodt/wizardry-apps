read_int_file() {
  file_path=$1
  fallback=${2:-0}
  value=""
  if [ -f "$file_path" ]; then
    value=$(sed -n '1p' "$file_path" 2>/dev/null || true)
  fi
  case "$value" in
    -[0-9]*|[0-9]*)
      if [ -n "$value" ]; then
        printf '%s' "$value"
        return 0
      fi
      ;;
  esac
  printf '%s' "$fallback"
}

