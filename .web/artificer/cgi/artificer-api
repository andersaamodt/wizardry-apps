        "$(json_escape "$idx")" "$(json_escape "$decision")" "$(json_escape "$match_mode")" "$(json_escape "$pattern")"
    done < "$remember_file"
  fi
  printf ']'

  printf ',"once":['
  first=1
  idx=0
  if [ -f "$once_file" ]; then
    while IFS= read -r line; do
      [ -n "$line" ] || continue
      idx=$((idx + 1))
      decision=$(printf '%s' "$line" | awk -F'\t' '{print $1}')
      match_mode=$(printf '%s' "$line" | awk -F'\t' '{print $2}')
