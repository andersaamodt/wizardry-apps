          "Model failed to emit control sections" "Fallback response generated for current mode"
        iteration_output=$(cat <<EOF
MODE_UPDATE:
target=$state_target
blocking=model returned empty response
confidence=$state_confidence
COMMANDS:
- git status --short
CONTRACT:
NONE
PATCH:
NONE
DONE_CLAIM:
no
PLAN_UPDATE:
$plan_text
CHECKPOINT:
