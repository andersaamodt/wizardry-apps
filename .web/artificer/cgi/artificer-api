    fi
    if [ "$run_time_budget" -lt 900 ] && printf '%s' "$prompt_lower_budget_runtime" | grep -Eq 'large[ -]?context|large[ -]?scale|architecture|monorepo|multi[- ]module|multi[- ]service|refactor|migration|distributed'; then
