    if [ -f "$running_file" ]; then
      printf '%s\n' "$(date +%s)" > "$running_stop_file"
      if [ -n "$running_pid" ] && kill -0 "$running_pid" 2>/dev/null; then
        kill -TERM "$running_pid" 2>/dev/null || true
        waited=0
