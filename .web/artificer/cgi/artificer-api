    fi
    if [ "$run_time_budget" -lt 1200 ] && printf '%s' "$prompt_lower_budget_runtime" | grep -Eq 'launch|business|go[- ]to[- ]market|compliance|legal|regulatory|operations|sales|pricing|growth'; then
