      queue_dir_for_mode=$(conversation_queue_dir_for "$conv_dir_for_mode")
      running_id_for_mode=$(read_file_line "$queue_dir_for_mode/running.id" "")
      if [ "$running_id_for_mode" = "$queue_item_id" ]; then
