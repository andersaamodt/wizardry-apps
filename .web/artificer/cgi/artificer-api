        ;;
    esac
    export ARTIFICER_MODEL_TIMEOUT_SCALE=$model_timeout_scale

    quick_mode=${ARTIFICER_QUICK_MODE:-0}
    simple_direct_prompt=0
    force_agent_execution=0
    if is_simple_direct_prompt "$user_prompt"; then
