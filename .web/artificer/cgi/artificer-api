    printf '%s\n' "$candidate_model" >> "$extras_file"
    extras_added=$((extras_added + 1))
    if [ "$extras_added" -ge 2 ]; then
      break
    fi
  done <<EOF
$all_models
EOF

  {
    printf '%s\n' "$primary_model"
    if [ -n "$preferred_model" ] && [ "$preferred_model" != "$primary_model" ]; then
      printf '%s\n' "$preferred_model"
    fi
    cat "$extras_file"
  } | awk '!seen[$0]++'

  rm -f "$extras_file"
}

