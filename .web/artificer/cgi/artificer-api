        quick_mode=1
        ;;
    esac
    if [ "$simple_direct_prompt" = "1" ]; then
      quick_mode=1
    fi
    if [ "$force_agent_execution" = "1" ]; then
      quick_mode=0
    fi
    case "$run_mode" in
      instant)
        quick_mode=1
        ;;
      auto)
        ;;
      programming)
        quick_mode=0
        force_agent_execution=1
        ;;
      chat)
        quick_mode=1
        simple_direct_prompt=1
        ;;
      report)
        quick_mode=0
        force_agent_execution=1
        ;;
      teacher)
        quick_mode=0
        force_agent_execution=1
        ;;
