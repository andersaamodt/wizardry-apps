#!/bin/sh
set -eu

WIZARDRY_DIR=${WIZARDRY_DIR:-$HOME/.wizardry}
PATH="$WIZARDRY_DIR/spells/.imps/cgi:$PATH:/usr/local/bin:/opt/homebrew/bin:$HOME/.local/bin:/usr/bin"
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
BACKEND="$SCRIPT_DIR/memetrader-backend.sh"

http-ok-json

method=${REQUEST_METHOD:-GET}
query=${QUERY_STRING:-}
post=""
if [ "$method" = "POST" ]; then
  post=$(cat)
fi

param() {
  key=$1
  value=""
  if [ -n "$post" ]; then
    value=$(get-query-param "$key" "$post")
  fi
  if [ -z "$value" ] && [ -n "$query" ]; then
    value=$(get-query-param "$key" "$query")
  fi
  printf '%s' "$value"
}

action=$(param action)
[ -n "$action" ] || action='status'

root=$(param root)

case "$action" in
  init|status)
    exec sh "$BACKEND" "$action" "$root"
    ;;
  list)
    exec sh "$BACKEND" "$action" "$root" "$(param limit)"
    ;;
  draw)
    exec sh "$BACKEND" "$action" "$root" "$(param tilt)"
    ;;
  ingest)
    exec sh "$BACKEND" ingest "$root" "$(param path)" "$(param msig)" "$(param families)" "$(param listing_type)" "$(param price_flat)"
    ;;
  vote)
    exec sh "$BACKEND" vote "$root" "$(param sha)" "$(param vote)"
    ;;
  tag)
    exec sh "$BACKEND" tag "$root" "$(param sha)" "$(param msig)" "$(param families)"
    ;;
  relate)
    exec sh "$BACKEND" relate "$root" "$(param sha)" "$(param rel)" "$(param target)"
    ;;
  lineage)
    exec sh "$BACKEND" lineage "$root" "$(param sha)" "$(param precursor)"
    ;;
  propose)
    exec sh "$BACKEND" propose "$root" "$(param sha)" "$(param curator)" "$(param payload)"
    ;;
  apply-patch)
    exec sh "$BACKEND" apply-patch "$root" "$(param patch)"
    ;;
  *)
    printf '{"ok":false,"error":"unknown action"}\n'
    ;;
esac
