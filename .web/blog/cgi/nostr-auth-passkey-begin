#!/bin/sh
# Begin passkey binding for a logged-in (Nostr-backed) account.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/ssh-auth-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session false; then
  exit 0
fi

pubkey=$(blog_get_nostr_pubkey "$BLOG_SESSION_USERNAME" 2>/dev/null || printf '')
if [ -z "$pubkey" ]; then
  blog_json_error "Account has no bound Nostr pubkey" "nostr_identity_required"
  exit 0
fi

fingerprint=$(printf '%s' "$pubkey" | blog_sha256)
challenge=$(ssh_auth_set_registration_challenge "$BLOG_SESSION_USERNAME")

printf '{"success":true,'
printf '"username":"%s",' "$(blog_json_escape "$BLOG_SESSION_USERNAME")"
printf '"fingerprint":"%s",' "$(blog_json_escape "$fingerprint")"
printf '"challenge":"%s"' "$(blog_json_escape "$challenge")"
printf '}\n'
