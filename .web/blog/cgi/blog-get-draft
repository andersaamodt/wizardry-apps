#!/bin/sh
# Load a single draft (admin only).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true; then
  exit 0
fi

draft_id=$(blog_param draft_id)
if [ -z "$draft_id" ]; then
  blog_json_error "draft_id is required" "invalid_request"
  exit 0
fi

meta=$(blog_draft_resolve_meta_path "$draft_id" 2>/dev/null || printf '')
body_file=$(blog_draft_resolve_content_path "$draft_id" 2>/dev/null || printf '')
if [ -z "$meta" ] || [ ! -f "$meta" ] || [ -z "$body_file" ] || [ ! -f "$body_file" ]; then
  blog_json_error "Draft not found" "not_found"
  exit 0
fi

title=$(config-get "$meta" title 2>/dev/null || printf 'Untitled')
tags=$(config-get "$meta" tags 2>/dev/null || printf '')
summary=$(config-get "$meta" summary 2>/dev/null || printf '')
publish_mode=$(config-get "$meta" publish_mode 2>/dev/null || printf 'draft')
status=$(config-get "$meta" status 2>/dev/null || printf 'draft')
scheduled_at=$(config-get "$meta" scheduled_at 2>/dev/null || printf '')
created_at=$(config-get "$meta" created_at 2>/dev/null || printf '')
updated_at=$(config-get "$meta" updated_at 2>/dev/null || printf '')
content=$(cat "$body_file" 2>/dev/null || printf '')

printf '{"success":true,"draft":{'
resolved_draft_id=$(config-get "$meta" draft_id 2>/dev/null || printf '')
[ -n "$resolved_draft_id" ] || resolved_draft_id="$draft_id"
printf '"draft_id":"%s",' "$(blog_json_escape "$resolved_draft_id")"
printf '"title":"%s",' "$(blog_json_escape "$title")"
printf '"tags":"%s",' "$(blog_json_escape "$tags")"
printf '"summary":"%s",' "$(blog_json_escape "$summary")"
printf '"publish_mode":"%s",' "$(blog_json_escape "$publish_mode")"
printf '"status":"%s",' "$(blog_json_escape "$status")"
printf '"scheduled_at":"%s",' "$(blog_json_escape "$scheduled_at")"
printf '"created_at":"%s",' "$(blog_json_escape "$created_at")"
printf '"updated_at":"%s",' "$(blog_json_escape "$updated_at")"
printf '"content":"%s"' "$(blog_json_escape "$content")"
printf '}}\n'
