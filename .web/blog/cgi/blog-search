#!/bin/sh
# Search public posts.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_send_html_headers

blog_run_scheduler >/dev/null 2>&1 || true

query=$(blog_param q)

printf '<div class="search-form">\n'
printf '  <form method="get" action="/cgi/blog-search">\n'
printf '    <input type="text" name="q" value="%s" placeholder="Search posts..." autofocus />\n' "$(blog_html_escape "$query")"
printf '    <button type="submit">Search</button>\n'
printf '  </form>\n'
printf '</div>\n'

if [ -z "$query" ]; then
  exit 0
fi

posts_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-search-posts.XXXXXX")
res_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-search-res.XXXXXX")
comment_counts_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-search-comment-counts.XXXXXX")
blog_collect_public_posts "$posts_tmp"
blog_nostr_comment_counts_build "$comment_counts_tmp"

query_lc=$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')
while IFS= read -r post_file; do
  title=$(blog_read_front_matter_value "$post_file" title 2>/dev/null || printf '')
  tags_raw=$(blog_read_front_matter_value "$post_file" tags 2>/dev/null || printf '')
  summary=$(blog_read_front_matter_value "$post_file" summary 2>/dev/null || printf '')
  tags_csv=$(printf '%s' "$tags_raw" | sed "s/^\[//;s/\]$//;s/\"//g;s/'//g")
  tags=$(blog_normalize_tags "$tags_csv")
  body=$(blog_read_markdown_body "$post_file")

  haystack=$(printf '%s\n%s\n%s\n%s\n' "$title" "$tags" "$summary" "$body" | tr '[:upper:]' '[:lower:]')
  if printf '%s' "$haystack" | grep -F "$query_lc" >/dev/null 2>&1; then
    printf '%s\n' "$post_file"
  fi
done < "$posts_tmp" > "$res_tmp"

count=$(wc -l < "$res_tmp" | tr -d ' ')
printf '<div class="search-results">\n'
if [ "$count" -eq 0 ]; then
  printf '  <p>No results found for <strong>%s</strong>.</p>\n' "$(blog_html_escape "$query")"
else
  printf '  <h2>Found %s result(s) for <strong>%s</strong></h2>\n' "$(blog_html_escape "$count")" "$(blog_html_escape "$query")"
  printf '  <div class="post-list">\n'
  while IFS= read -r post_file; do
    title=$(blog_read_front_matter_value "$post_file" title 2>/dev/null || printf 'Untitled')
    published_at=$(blog_read_front_matter_value "$post_file" published_at 2>/dev/null || printf '')
    summary=$(blog_read_front_matter_value "$post_file" summary 2>/dev/null || printf '')
    tags_raw=$(blog_read_front_matter_value "$post_file" tags 2>/dev/null || printf '')
    tags_csv=$(printf '%s' "$tags_raw" | sed "s/^\[//;s/\]$//;s/\"//g;s/'//g")
    tags=$(blog_normalize_tags "$tags_csv")
    url=$(blog_rel_post_html_url "$post_file")
    post_address=$(blog_post_nostr_address_for_file "$post_file")
    comment_count=$(blog_nostr_comment_count_lookup "$comment_counts_tmp" "$post_address")
    pub_date=${published_at%%T*}

    printf '    <article class="post-item">\n'
    printf '      <h3 class="post-title"><a href="%s">%s</a></h3>\n' "$(blog_html_escape "$url")" "$(blog_html_escape "$title")"
    printf '      <div class="post-meta">'
    if [ -n "$pub_date" ]; then
      printf '<span class="post-date">%s</span>' "$(blog_html_escape "$pub_date")"
    fi
    if [ "$comment_count" -gt 0 ]; then
      printf ' <span class="post-comments-count">%s comments</span>' "$(blog_html_escape "$comment_count")"
    else
      printf ' <span class="post-comments-count">0 comments</span>'
    fi
    printf '</div>\n'

    if [ -n "$summary" ]; then
      printf '      <p class="post-summary">%s</p>\n' "$(blog_html_escape "$summary")"
    fi

    if [ -n "$tags" ]; then
      printf '      <div class="tags">\n'
      printf '%s\n' "$tags" | tr ',' '\n' | while IFS= read -r tag; do
        clean=$(printf '%s' "$tag" | sed 's/^ *//;s/ *$//')
        [ -n "$clean" ] || continue
        printf '        <a href="/pages/tags.html#%s" class="tag">%s</a>\n' "$(blog_html_escape "$clean")" "$(blog_html_escape "$clean")"
      done
      printf '      </div>\n'
    fi

    printf '    </article>\n\n'
  done < "$res_tmp"
  printf '  </div>\n'
fi
printf '</div>\n'

rm -f "$posts_tmp" "$res_tmp" "$comment_counts_tmp"
