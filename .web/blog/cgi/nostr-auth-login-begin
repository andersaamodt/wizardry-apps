#!/bin/sh
# Begin Nostr login by issuing a challenge bound to a pubkey.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! command -v nostril >/dev/null 2>&1; then
  blog_json_error "Nostr login requires nostril on the server" "nostril_required"
  exit 0
fi

pubkey=$(blog_param pubkey)
pubkey=$(blog_validate_nostr_pubkey "$pubkey" 2>/dev/null || printf '')
if [ -z "$pubkey" ]; then
  blog_json_error "Valid Nostr hex pubkey is required" "invalid_pubkey"
  exit 0
fi

if ! request_info=$(blog_create_nostr_login_request "$pubkey" 2>/dev/null); then
  blog_json_error "Unable to create login challenge" "request_failed"
  exit 0
fi

request_id=${request_info%%;*}
challenge=${request_info#*;}

printf '{"success":true,'
printf '"request_id":"%s",' "$(blog_json_escape "$request_id")"
printf '"challenge":"%s",' "$(blog_json_escape "$challenge")"
printf '"pubkey":"%s",' "$(blog_json_escape "$pubkey")"
printf '"origin":"%s"' "$(blog_json_escape "$HTTP_HOST")"
printf '}\n'
