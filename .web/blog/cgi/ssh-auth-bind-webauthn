#!/bin/sh
# Bind WebAuthn credential to SSH identity.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/ssh-auth-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

username=$(blog_param username)
credential_id=$(blog_param credential_id)
public_key_b64=$(blog_param public_key)
fingerprint=$(blog_param fingerprint)
client_data_b64=$(blog_param client_data_json)

if ! blog_validate_username "$username"; then
  blog_json_error "Invalid username" "invalid_username"
  exit 0
fi

if [ -z "$credential_id" ] || [ -z "$public_key_b64" ] || [ -z "$fingerprint" ] || [ -z "$client_data_b64" ]; then
  blog_json_error "Missing required parameters" "invalid_request"
  exit 0
fi

profile=$(ssh_auth_profile_path "$username")
if [ ! -f "$profile" ]; then
  blog_json_error "User not found" "user_not_found"
  exit 0
fi

stored_fp=$(config-get "$profile" fingerprint 2>/dev/null || printf '')
if [ "$stored_fp" != "$fingerprint" ]; then
  blog_json_error "Fingerprint mismatch" "fingerprint_mismatch"
  exit 0
fi

challenge=$(config-get "$profile" registration_challenge 2>/dev/null || printf '')
if [ -z "$challenge" ]; then
  blog_json_error "Missing registration challenge" "challenge_missing"
  exit 0
fi

if ! ssh_auth_verify_client_data "$client_data_b64" "$challenge" "webauthn.create"; then
  blog_json_error "WebAuthn challenge/origin validation failed" "webauthn_validation_failed"
  exit 0
fi

delegates_dir=$(ssh_auth_delegate_dir "$username")
mkdir -p "$delegates_dir"

existing=$(ssh_auth_find_delegate_by_credential "$username" "$credential_id" 2>/dev/null || printf '')
if [ -n "$existing" ]; then
  delegate_file="$existing"
  delegate_id=$(basename "$existing" .conf)
else
  delegate_id=$(blog_random_token 10)
  delegate_file="$delegates_dir/$delegate_id.conf"
fi

config-set "$delegate_file" delegate_id "$delegate_id"
config-set "$delegate_file" credential_id "$credential_id"
config-set "$delegate_file" public_key_b64 "$public_key_b64"
config-set "$delegate_file" created_at "$(blog_now_iso)"
config-set "$delegate_file" sign_count "0"
config-set "$delegate_file" last_used_at ""

# one-time use registration challenge
config-set "$profile" registration_challenge ""
config-set "$profile" registration_challenge_created "0"

printf '{"success":true,'
printf '"username":"%s",' "$(blog_json_escape "$username")"
printf '"fingerprint":"%s",' "$(blog_json_escape "$fingerprint")"
printf '"delegate_id":"%s"' "$(blog_json_escape "$delegate_id")"
printf '}\n'
