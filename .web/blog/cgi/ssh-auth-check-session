#!/bin/sh
# Validate session and return user/admin context.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/ssh-auth-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

token=$(blog_param session_token)
if ! blog_load_session "$token"; then
  printf '{"success":false,"authenticated":false}\n'
  exit 0
fi

# Dynamic admin check.
if blog_user_is_admin "$BLOG_SESSION_USERNAME"; then
  BLOG_SESSION_IS_ADMIN=true
fi
blog_extend_session

player_name=$(blog_get_player_name "$BLOG_SESSION_USERNAME" 2>/dev/null || printf '%s' "$BLOG_SESSION_USERNAME")
nostr_pubkey=$(blog_get_nostr_pubkey "$BLOG_SESSION_USERNAME" 2>/dev/null || printf '')
session_user_pubkey=$(blog_validate_nostr_pubkey "${BLOG_SESSION_USER_PUBKEY-}" 2>/dev/null || printf '')
session_signer_pubkey=$(blog_validate_nostr_pubkey "${BLOG_SESSION_SIGNER_PUBKEY-}" 2>/dev/null || printf '')
session_delegation_id=${BLOG_SESSION_DELEGATION_ID-}
session_auth_method=${BLOG_SESSION_AUTH_METHOD-nostr}
session_force_interactive=${BLOG_SESSION_FORCE_INTERACTIVE-false}
profile=$(blog_user_profile "$BLOG_SESSION_USERNAME")
ssh_fingerprint=''
if [ -f "$profile" ]; then
  ssh_fingerprint=$(config-get "$profile" ssh_fingerprint 2>/dev/null || printf '')
fi

printf '{"success":true,'
printf '"authenticated":true,'
printf '"username":"%s",' "$(blog_json_escape "$BLOG_SESSION_USERNAME")"
printf '"player_name":"%s",' "$(blog_json_escape "$player_name")"
printf '"nostr_pubkey":"%s",' "$(blog_json_escape "$nostr_pubkey")"
printf '"session_user_pubkey":"%s",' "$(blog_json_escape "$session_user_pubkey")"
printf '"session_signer_pubkey":"%s",' "$(blog_json_escape "$session_signer_pubkey")"
printf '"session_delegation_id":"%s",' "$(blog_json_escape "$session_delegation_id")"
printf '"session_auth_method":"%s",' "$(blog_json_escape "$session_auth_method")"
printf '"session_force_interactive":"%s",' "$(blog_json_escape "$session_force_interactive")"
printf '"ssh_fingerprint":"%s",' "$(blog_json_escape "$ssh_fingerprint")"
printf '"fingerprint":"%s",' "$(blog_json_escape "$BLOG_SESSION_FINGERPRINT")"
printf '"is_admin":%s,' "$BLOG_SESSION_IS_ADMIN"
printf '"csrf_token":"%s"' "$(blog_json_escape "$BLOG_SESSION_CSRF")"
printf '}\n'
