#!/bin/sh
# Update per-account settings (currently player display name).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session false true; then
  exit 0
fi

player_name=$(blog_param player_name)
rename_authored_posts=$(blog_param rename_authored_posts)
preview_rename=$(blog_param preview_rename)
player_name=$(printf '%s' "$player_name" | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')

if ! blog_validate_player_name "$player_name"; then
  blog_json_error "Invalid player name. Use up to 40 letters/numbers/spaces/._-" "invalid_player_name"
  exit 0
fi

old_player_name=$(blog_get_player_name "$BLOG_SESSION_USERNAME" 2>/dev/null || printf '%s' "$BLOG_SESSION_USERNAME")
rename_candidate_count=0
if [ "$old_player_name" != "$player_name" ]; then
  rename_candidate_count=$(blog_count_authored_posts_by_author "$old_player_name")
  case "$rename_candidate_count" in ''|*[!0-9]*) rename_candidate_count=0 ;; esac
fi

if [ "$preview_rename" = "true" ]; then
  printf '{"success":true,'
  printf '"username":"%s",' "$(blog_json_escape "$BLOG_SESSION_USERNAME")"
  printf '"old_player_name":"%s",' "$(blog_json_escape "$old_player_name")"
  printf '"player_name":"%s",' "$(blog_json_escape "$player_name")"
  printf '"rename_candidate_count":%s' "$rename_candidate_count"
  printf '}\n'
  exit 0
fi

blog_set_player_name "$BLOG_SESSION_USERNAME" "$player_name"
renamed_posts=0
if [ "$rename_authored_posts" = "true" ] && [ "$rename_candidate_count" -gt 0 ] && [ "$old_player_name" != "$player_name" ]; then
  renamed_posts=$(blog_rename_authored_posts "$old_player_name" "$player_name")
  case "$renamed_posts" in ''|*[!0-9]*) renamed_posts=0 ;; esac
  if [ "$renamed_posts" -gt 0 ]; then
    blog_run_build_async
  fi
fi

printf '{"success":true,'
printf '"username":"%s",' "$(blog_json_escape "$BLOG_SESSION_USERNAME")"
printf '"old_player_name":"%s",' "$(blog_json_escape "$old_player_name")"
printf '"player_name":"%s",' "$(blog_json_escape "$player_name")"
printf '"rename_candidate_count":%s,' "$rename_candidate_count"
printf '"renamed_posts":%s' "$renamed_posts"
printf '}\n'
