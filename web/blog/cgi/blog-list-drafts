#!/bin/sh
# List drafts (admin only).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true; then
  exit 0
fi

tmp=$(mktemp "${TMPDIR:-/tmp}/blog-drafts.XXXXXX")
blog_find_draft_meta | while IFS= read -r meta; do
  updated=$(config-get "$meta" updated_at 2>/dev/null || printf '1970-01-01T00:00:00Z')
  printf '%s\t%s\n' "$updated" "$meta"
done | sort -r > "$tmp"

tab=$(printf '\t')
printf '{"success":true,"drafts":['
first=1
while IFS="$tab" read -r _ meta; do
  [ -f "$meta" ] || continue
  draft_id=$(config-get "$meta" draft_id 2>/dev/null || printf '')
  [ -n "$draft_id" ] || continue
  title=$(config-get "$meta" title 2>/dev/null || printf 'Untitled')
  tags=$(config-get "$meta" tags 2>/dev/null || printf '')
  summary=$(config-get "$meta" summary 2>/dev/null || printf '')
  publish_mode=$(config-get "$meta" publish_mode 2>/dev/null || printf 'draft')
  status=$(config-get "$meta" status 2>/dev/null || printf 'draft')
  scheduled_at=$(config-get "$meta" scheduled_at 2>/dev/null || printf '')
  created_at=$(config-get "$meta" created_at 2>/dev/null || printf '')
  updated_at=$(config-get "$meta" updated_at 2>/dev/null || printf '')
  if [ "$status" != "draft" ] || [ "$publish_mode" != "draft" ]; then
    continue
  fi
  body_file=$(dirname "$meta")/content.md
  content_excerpt=""
  if [ -f "$body_file" ]; then
    content_excerpt=$(blog_auto_summary_from_content "$(cat "$body_file" 2>/dev/null || printf '')")
  fi

  if [ "$first" -eq 0 ]; then
    printf ','
  fi
  first=0

  printf '{'
  printf '"draft_id":"%s",' "$(blog_json_escape "$draft_id")"
  printf '"title":"%s",' "$(blog_json_escape "$title")"
  printf '"tags":"%s",' "$(blog_json_escape "$tags")"
  printf '"summary":"%s",' "$(blog_json_escape "$summary")"
  printf '"content_excerpt":"%s",' "$(blog_json_escape "$content_excerpt")"
  printf '"created_at":"%s",' "$(blog_json_escape "$created_at")"
  printf '"updated_at":"%s"' "$(blog_json_escape "$updated_at")"
  printf '}'
done < "$tmp"
printf ']}\n'

rm -f "$tmp"
